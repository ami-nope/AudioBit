<Window x:Class="AudioBit.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:infra="clr-namespace:AudioBit.Installer.Infrastructure"
        xmlns:local="clr-namespace:AudioBit.Installer"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding ModeHeadline}"
        Width="356"
        Height="690"
        MinWidth="356"
        MinHeight="690"
        MaxWidth="356"
        MaxHeight="690"
        Background="#0B0717"
        FontFamily="Segoe UI"
        Foreground="#F4F2F8"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:ProgressToGridLengthConverter x:Key="ProgressToGridLengthConverter" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F7EEF8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#C2B0CD" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9D89B1" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF9C2F" />
        <SolidColorBrush x:Key="AccentOrangeBorderBrush" Color="#FFD19E" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#5A4577" />
        <SolidColorBrush x:Key="FooterBorderBrush" Color="#5A4179" />
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#7D4E90" />
        <SolidColorBrush x:Key="ShellInnerBorderBrush" Color="#5E3D7E" />
        <SolidColorBrush x:Key="OptionBrush" Color="#261935" />
        <SolidColorBrush x:Key="OptionBorderBrush" Color="#5A3A76" />
        <SolidColorBrush x:Key="OptionHoverBrush" Color="#332147" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#351A27" />
        <SolidColorBrush x:Key="BadgeBorderBrush" Color="#B75A2E" />
        <SolidColorBrush x:Key="BackdropSparkBrush" Color="#7F4E66" />
        <SolidColorBrush x:Key="PanelOverlayStrokeBrush" Color="#6E4A8E" />
        <SolidColorBrush x:Key="FieldSurfaceBrush" Color="#261A34" />
        <SolidColorBrush x:Key="StatusCardBrush" Color="#2D1730" />
        <SolidColorBrush x:Key="ProgressTrackBrush" Color="#2A1937" />

        <LinearGradientBrush x:Key="OuterBackdropBrush" StartPoint="0,0" EndPoint="0.95,1">
            <GradientStop Offset="0" Color="#150C2A" />
            <GradientStop Offset="0.52" Color="#1D1033" />
            <GradientStop Offset="1" Color="#280E2D" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#231538" />
            <GradientStop Offset="1" Color="#1A0F2D" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TopBarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#2E1E45" />
            <GradientStop Offset="1" Color="#261A3B" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BrandTileBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFA637" />
            <GradientStop Offset="1" Color="#FF5C25" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SoftCardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#2B1C3E" />
            <GradientStop Offset="1" Color="#241733" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FooterBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#2A1A3F" />
            <GradientStop Offset="1" Color="#231537" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="ShellGlowBrush"
                             Center="0.5,0"
                             GradientOrigin="0.5,0"
                             RadiusX="1"
                             RadiusY="0.62">
            <GradientStop Offset="0" Color="#4DFF8240" />
            <GradientStop Offset="0.48" Color="#16FF8240" />
            <GradientStop Offset="1" Color="#00FF8240" />
        </RadialGradientBrush>

        <RadialGradientBrush x:Key="NebulaGlowTopBrush"
                             Center="0.16,0.08"
                             GradientOrigin="0.16,0.08"
                             RadiusX="0.86"
                             RadiusY="0.66">
            <GradientStop Offset="0" Color="#44C36EFF" />
            <GradientStop Offset="0.38" Color="#22905DFF" />
            <GradientStop Offset="1" Color="#00905DFF" />
        </RadialGradientBrush>

        <RadialGradientBrush x:Key="NebulaGlowBottomBrush"
                             Center="0.77,0.86"
                             GradientOrigin="0.77,0.86"
                             RadiusX="0.86"
                             RadiusY="0.72">
            <GradientStop Offset="0" Color="#6AF77B3D" />
            <GradientStop Offset="0.44" Color="#35E95A4A" />
            <GradientStop Offset="1" Color="#00E95A4A" />
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFA437" />
            <GradientStop Offset="0.48" Color="#FF7B2A" />
            <GradientStop Offset="1" Color="#FF4E25" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FFB24D" />
            <GradientStop Offset="0.48" Color="#FF8E35" />
            <GradientStop Offset="1" Color="#FF5F30" />
        </LinearGradientBrush>

        <Style x:Key="StepBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Background" Value="{StaticResource BadgeBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BadgeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <Style x:Key="TrafficButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Ellipse x:Name="Orb"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter x:Name="GlyphPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.96" />
                                <Setter TargetName="GlyphPresenter" Property="Opacity" Value="0.74" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Foreground" Value="#FFF8F3EE" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="27">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  Direction="90"
                                                  Opacity="0.5"
                                                  ShadowDepth="0"
                                                  Color="#9CFF6B2A" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="54" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource OptionBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OptionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="27">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource OptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OptionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentOrangeBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder"
                                Margin="0,0,0,12"
                                Padding="16,15"
                                Background="{StaticResource OptionBrush}"
                                BorderBrush="{StaticResource OptionBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="22">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="22"
                                      Height="22"
                                      VerticalAlignment="Top">
                                    <Border x:Name="CheckBoxBorder"
                                            Background="#2A1D38"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="7" />
                                    <Path x:Name="CheckMark"
                                          Margin="4"
                                          Data="M1,6 L4.2,9.2 L11,2.2"
                                          Stroke="#FFF7F7F9"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="14,0,0,0"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource OptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource AccentOrangeBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource AccentOrangeBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallerScrollBarButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="InstallerScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="ThumbBorder"
                                Margin="2"
                                Background="#9F6A4A9D"
                                BorderBrush="#C58C56B2"
                                BorderThickness="1"
                                CornerRadius="999" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#C57A53B4" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#E8BC7FCC" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#DC8E4BAF" />
                                <Setter TargetName="ThumbBorder" Property="BorderBrush" Value="#FFD699" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallerScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="11" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Border Margin="2,2,1,2"
                                    Background="#2A1C39"
                                    BorderBrush="#5B3F79"
                                    BorderThickness="1"
                                    CornerRadius="999" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Style="{StaticResource InstallerScrollBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource InstallerScrollThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Style="{StaticResource InstallerScrollBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="11" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent"
          MouseLeftButtonDown="ShellBackground_OnMouseLeftButtonDown">
        <Grid IsHitTestVisible="False">
            <Rectangle Fill="{StaticResource OuterBackdropBrush}" />
            <Rectangle Fill="{StaticResource NebulaGlowTopBrush}" />
            <Rectangle Fill="{StaticResource NebulaGlowBottomBrush}" />
            <Ellipse Width="8"
                     Height="8"
                     Margin="62,74,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="{StaticResource BackdropSparkBrush}" />
            <Ellipse Width="6"
                     Height="6"
                     Margin="300,94,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#8A8867A8" />
            <Ellipse Width="7"
                     Height="7"
                     Margin="270,510,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#A0634C9D" />
            <Ellipse Width="430"
                     Height="260"
                     Margin="-210,420,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#2BB56CF4" />
            <Ellipse Width="500"
                     Height="300"
                     Margin="70,-140,0,0"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Fill="#1E7D56E8" />
            <Path Margin="-34,548,-10,-76"
                  Stroke="#38FF834A"
                  StrokeThickness="2.3"
                  Data="M-20,120 C130,20 250,220 420,92 560,10 660,112 760,84" />
            <Path Margin="-92,500,-70,-30"
                  Stroke="#24D572BD"
                  StrokeThickness="1.6"
                  Data="M-20,118 C100,58 240,170 360,122 520,58 620,120 760,86" />
        </Grid>

        <Border x:Name="ShellBorder"
                Margin="8,14,8,14"
                Background="{StaticResource ShellBackgroundBrush}"
                BorderBrush="{StaticResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="34">
            <Border.Effect>
                <DropShadowEffect BlurRadius="34"
                                  Direction="90"
                                  Opacity="0.55"
                                  ShadowDepth="18"
                                  Color="#A01D0D28" />
            </Border.Effect>
            <Grid>
                    <Ellipse Width="290"
                             Height="170"
                             Margin="0,-102,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Fill="{StaticResource ShellGlowBrush}"
                             IsHitTestVisible="False" />

                    <Border Margin="2"
                            BorderBrush="{StaticResource ShellInnerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="31">
                        <Grid x:Name="ShellClipHost">
                            <Border Background="Transparent"
                                    MouseLeftButtonDown="ShellBackground_OnMouseLeftButtonDown" />
                            <Border Margin="1"
                                    BorderBrush="{StaticResource PanelOverlayStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="30"
                                    Opacity="0.55"
                                    IsHitTestVisible="False" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="96" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{StaticResource TopBarBackgroundBrush}"
                                        BorderBrush="#573B73"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="30,30,0,0"
                                        PreviewMouseLeftButtonDown="TopBar_OnPreviewMouseLeftButtonDown">
                        <Grid Margin="18,18,18,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="50"
                                    Height="50"
                                    Margin="0,0,12,0"
                                    Background="{StaticResource BrandTileBrush}"
                                    BorderBrush="{StaticResource AccentOrangeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="15">
                                <Viewbox Width="30"
                                         Height="30"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Stroke="#FFF7F1"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ModeHeadline}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding ModePillText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="0,2,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Margin="0,0,6,0"
                                        Background="#5BEB73"
                                        BorderBrush="#40B155"
                                        Click="MinimizeButton_Click"
                                        ToolTip="Minimize"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#0F2817"
                                              StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1,4 L7,4" />
                                    </Canvas>
                                </Button>
                                <Button Background="#FF5477"
                                        BorderBrush="#CB3D5C"
                                        Click="CloseButton_Click"
                                        ToolTip="Close"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#34110F"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1.3,1.3 L6.7,6.7 M6.7,1.3 L1.3,6.7" />
                                    </Canvas>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="18,18,18,0">
                        <Grid Visibility="{Binding ShowLocationStep, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border HorizontalAlignment="Left"
                                    Style="{StaticResource StepBadgeStyle}">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentOrangeBrush}"
                                           Text="STEP 1 OF 3" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0,16,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Choose an install folder"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="AudioBit defaults to your local Programs folder. Change it only if you want a custom path."
                                       TextWrapping="Wrap" />

                            <StackPanel Grid.Row="3"
                                        Margin="0,20,0,0">
                                <Border Padding="18"
                                        Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding InstallPathBadgeText}" />
                                        <Border Margin="0,14,0,0"
                                                Padding="15,13"
                                                Background="{StaticResource FieldSurfaceBrush}"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="20">
                                            <TextBox Style="{StaticResource PathTextBoxStyle}"
                                                     IsEnabled="{Binding CanInstall}"
                                                     Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <TextBlock Margin="0,14,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding ModeSubtitle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="18"
                                        Background="{StaticResource StatusCardBrush}"
                                        BorderBrush="#895267"
                                        BorderThickness="1"
                                        Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   Text="{Binding PhaseText}" />
                                        <TextBlock Margin="0,9,0,0"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding StatusText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <UniformGrid Margin="0,16,0,0"
                                             Columns="2">
                                    <Border Margin="0,0,8,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Per-user install. No admin prompt required."
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <Border Margin="8,0,0,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Registers AudioBit and leaves a themed uninstaller behind."
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding ShowOptionsStep, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border HorizontalAlignment="Left"
                                    Style="{StaticResource StepBadgeStyle}">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentOrangeBrush}"
                                           Text="STEP 2 OF 3" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0,16,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Choose setup options"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Pick the shortcuts and pins setup should create after the files are installed."
                                       TextWrapping="Wrap" />

                            <ScrollViewer Grid.Row="3"
                                          Margin="0,20,0,0"
                                          CanContentScroll="False"
                                          HorizontalScrollBarVisibility="Disabled"
                                          PanningMode="VerticalFirst"
                                          PanningDeceleration="0.001"
                                          infra:SmoothScrollBehavior.IsEnabled="True"
                                          infra:SmoothScrollBehavior.SmoothingDuration="280"
                                          infra:SmoothScrollBehavior.WheelStep="10"
                                          VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style BasedOn="{StaticResource InstallerScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                </ScrollViewer.Resources>
                                <StackPanel Margin="0,0,4,8">
                                    <Border Padding="18"
                                            Style="{StaticResource SoftCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="10.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="INSTALL TARGET" />
                                            <TextBlock Margin="0,9,0,0"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding InstallPath}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,12,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding SetupSummaryText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,16,0,0">
                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding CreateStartMenuShortcut}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Create Start menu shortcut" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Adds AudioBit and its uninstaller to the Start menu folder."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding CreateDesktopShortcut}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Create desktop shortcut" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Drops a direct launcher on the current user's desktop."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding PinToStart}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Pin AudioBit to Start" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Requests a Start pin using the installed shortcut."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding PinToTaskbar}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Pin AudioBit to the taskbar" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Requests a taskbar pin from the installed executable."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding LaunchAfterInstall}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Launch AudioBit after install" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Opens AudioBit as soon as setup finishes successfully."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>
                                    </StackPanel>

                                    <Border Margin="0,8,0,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}"
                                            Visibility="{Binding ShowPinningNote, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding PinningNoteText}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="18,18,18,0"
                          Visibility="{Binding ShowProgressStep, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border HorizontalAlignment="Left"
                                Style="{StaticResource StepBadgeStyle}">
                            <TextBlock FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentOrangeBrush}"
                                       Text="{Binding ProgressStepTag}" />
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Margin="0,16,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding ProgressTitleText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />

                        <Border Grid.Row="3"
                                Margin="0,20,0,0"
                                Padding="20"
                                Style="{StaticResource SoftCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="54"
                                            Height="54"
                                            Background="#2F1C2F"
                                            BorderBrush="#8A5F45"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <Viewbox Width="28"
                                                 Height="28"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="32" Height="32">
                                                <Path Stroke="{StaticResource AccentOrangeBrush}"
                                                      StrokeThickness="3.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   Text="{Binding PhaseText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding ProgressPercentText}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1"
                                      Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding ProgressBarLabelText}" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ProgressPercentText}" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      Height="12"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding ProgressValue, Converter={StaticResource ProgressToGridLengthConverter}}" />
                                        <ColumnDefinition Width="{Binding RemainingProgressValue, Converter={StaticResource ProgressToGridLengthConverter}}" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2"
                                            Background="{StaticResource ProgressTrackBrush}"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999" />
                                    <Border Grid.Column="0"
                                            Background="{StaticResource PrimaryButtonBrush}"
                                            CornerRadius="999" />
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Margin="0,16,0,0">
                            <Border Padding="18"
                                    Style="{StaticResource SoftCardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="{Binding PathSectionTitle}" />
                                    <TextBlock Margin="0,9,0,0"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding InstallPath}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <UniformGrid Margin="0,14,0,0"
                                         Columns="2">
                                <Border Margin="0,0,8,0"
                                        Padding="15"
                                        Style="{StaticResource SoftCardStyle}">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding PayloadSummaryText}"
                                               TextWrapping="Wrap" />
                                </Border>
                                <Border Margin="8,0,0,0"
                                        Padding="15"
                                        Style="{StaticResource SoftCardStyle}">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ModeSummaryText}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </UniformGrid>

                            <Border Margin="0,14,0,0"
                                    Padding="15"
                                    Style="{StaticResource SoftCardStyle}"
                                    Visibility="{Binding IsInstallMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding SetupSummaryText}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>

                                <Border Grid.Row="2"
                                        Margin="18,16,18,18"
                                        Padding="16"
                                        Background="{StaticResource FooterBackgroundBrush}"
                                        BorderBrush="{StaticResource FooterBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="24">
                                    <Grid>
                                        <Grid Visibility="{Binding ShowLocationStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Default folder first, then continue into setup options."
                                                       TextWrapping="Wrap" />

                                            <UniformGrid Grid.Row="1"
                                                         Margin="0,12,0,0"
                                                         Columns="2">
                                                <Button Margin="0,0,8,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BrowsePathButton_Click"
                                                        Content="Change Folder"
                                                        IsEnabled="{Binding CanInstall}" />
                                                <Button Margin="8,0,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="ProceedButton_Click"
                                                        Content="Next"
                                                        IsEnabled="{Binding CanProceedFromLocation}" />
                                            </UniformGrid>
                                        </Grid>

                                        <Grid Visibility="{Binding ShowOptionsStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Review the extras, then start the install."
                                                       TextWrapping="Wrap" />

                                            <UniformGrid Grid.Row="1"
                                                         Margin="0,12,0,0"
                                                         Columns="2">
                                                <Button Margin="0,0,8,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BackButton_Click"
                                                        Content="Back"
                                                        IsEnabled="{Binding CanInstall}" />
                                                <Button Margin="8,0,0,0"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="InstallButton_Click"
                                                        Content="{Binding InstallButtonText}"
                                                        IsEnabled="{Binding CanRunPrimaryAction}" />
                                            </UniformGrid>
                                        </Grid>

                                        <Grid Visibility="{Binding ShowProgressStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="The bundled AudioBit.Setup payload contains the updater-ready app layout."
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button MinWidth="122"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BackButton_Click"
                                                        Content="Back"
                                                        Visibility="{Binding ShowReturnToOptionsButton, Converter={StaticResource BoolToVisibility}}" />

                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button MinWidth="136"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="LaunchButton_Click"
                                                            Content="Launch AudioBit"
                                                            Visibility="{Binding ShowLaunchButton, Converter={StaticResource BoolToVisibility}}" />
                                                    <Button Margin="10,0,0,0"
                                                            MinWidth="132"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            Click="InstallButton_Click"
                                                            Content="{Binding InstallButtonText}"
                                                            IsEnabled="{Binding CanRunPrimaryAction}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
    </Grid>
</Window>
