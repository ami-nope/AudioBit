<Window x:Class="AudioBit.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AudioBit.Installer"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="{Binding ModeHeadline}"
        Width="356"
        Height="690"
        MinWidth="356"
        MinHeight="690"
        MaxWidth="356"
        MaxHeight="690"
        Background="#0D0F16"
        FontFamily="Segoe UI"
        Foreground="#F4F2F8"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:ProgressToGridLengthConverter x:Key="ProgressToGridLengthConverter" />

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F2F8" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A7A8B7" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#8B8D9E" />
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FF8D33" />
        <SolidColorBrush x:Key="AccentOrangeBorderBrush" Color="#FFC38D" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#434557" />
        <SolidColorBrush x:Key="FooterBorderBrush" Color="#3A3B4D" />
        <SolidColorBrush x:Key="ShellBorderBrush" Color="#3B3E51" />
        <SolidColorBrush x:Key="ShellInnerBorderBrush" Color="#54586D" />
        <SolidColorBrush x:Key="OptionBrush" Color="#2B2D39" />
        <SolidColorBrush x:Key="OptionBorderBrush" Color="#4B4D61" />
        <SolidColorBrush x:Key="OptionHoverBrush" Color="#353746" />
        <SolidColorBrush x:Key="BadgeBrush" Color="#33231A" />
        <SolidColorBrush x:Key="BadgeBorderBrush" Color="#6E492E" />

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#2B2B39" />
            <GradientStop Offset="1" Color="#191A24" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TopBarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#343545" />
            <GradientStop Offset="1" Color="#2A2B38" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BrandTileBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF9B3E" />
            <GradientStop Offset="1" Color="#F36D1E" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SoftCardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#323340" />
            <GradientStop Offset="1" Color="#2D2E3B" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="FooterBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#252632" />
            <GradientStop Offset="1" Color="#21222D" />
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="ShellGlowBrush"
                             Center="0.5,0"
                             GradientOrigin="0.5,0"
                             RadiusX="1"
                             RadiusY="0.62">
            <GradientStop Offset="0" Color="#34FF9A3E" />
            <GradientStop Offset="0.48" Color="#12FF9A3E" />
            <GradientStop Offset="1" Color="#00FF9A3E" />
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF8D33" />
            <GradientStop Offset="1" Color="#F07A1F" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0" Color="#FF9947" />
            <GradientStop Offset="1" Color="#F5862D" />
        </LinearGradientBrush>

        <Style x:Key="TrafficButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Ellipse x:Name="Orb"
                                     Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="{TemplateBinding BorderThickness}" />
                            <ContentPresenter x:Name="GlyphPresenter"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Opacity="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.96" />
                                <Setter TargetName="GlyphPresenter" Property="Opacity" Value="0.74" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Orb" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Foreground" Value="#FFF8F3EE" />
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentOrangeBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource PrimaryButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource OptionBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OptionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource OptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SoftCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SoftCardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource OptionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
        </Style>

        <Style x:Key="PathTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentOrangeBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="OptionCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder"
                                Margin="0,0,0,12"
                                Padding="16,15"
                                Background="{StaticResource OptionBrush}"
                                BorderBrush="{StaticResource OptionBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="20"
                                      Height="20"
                                      VerticalAlignment="Top">
                                    <Border x:Name="CheckBoxBorder"
                                            Background="#20161B24"
                                            BorderBrush="#6B7088"
                                            BorderThickness="1"
                                            CornerRadius="6" />
                                    <Path x:Name="CheckMark"
                                          Margin="4"
                                          Data="M1,6 L4.2,9.2 L11,2.2"
                                          Stroke="#FFF7F7F9"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed" />
                                </Grid>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="14,0,0,0"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource OptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBoxBorder" Property="Background" Value="{StaticResource AccentOrangeBrush}" />
                                <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{StaticResource AccentOrangeBrush}" />
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent"
          MouseLeftButtonDown="ShellBackground_OnMouseLeftButtonDown">
        <Border x:Name="ShellBorder"
                Margin="3"
                Background="{StaticResource ShellBackgroundBrush}"
                BorderBrush="{StaticResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="25">
                <Grid>
                    <Ellipse Width="290"
                             Height="170"
                             Margin="0,-102,0,0"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Top"
                             Fill="{StaticResource ShellGlowBrush}"
                             IsHitTestVisible="False" />

                    <Border Margin="2"
                            BorderBrush="{StaticResource ShellInnerBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid x:Name="ShellClipHost">
                            <Border Background="Transparent"
                                    MouseLeftButtonDown="ShellBackground_OnMouseLeftButtonDown" />

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="88" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{StaticResource TopBarBackgroundBrush}"
                                        CornerRadius="21,21,0,0"
                                        PreviewMouseLeftButtonDown="TopBar_OnPreviewMouseLeftButtonDown">
                        <Grid Margin="18,15,18,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="50"
                                    Height="50"
                                    Margin="0,0,12,0"
                                    Background="{StaticResource BrandTileBrush}"
                                    BorderBrush="{StaticResource AccentOrangeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Viewbox Width="30"
                                         Height="30"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Stroke="#FFF7F1"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Text="{Binding ModeHeadline}" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="{Binding ModePillText}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="0,2,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Margin="0,0,6,0"
                                        Background="#2DCB5A"
                                        BorderBrush="#1D9440"
                                        Click="MinimizeButton_Click"
                                        ToolTip="Minimize"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#0F2817"
                                              StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1,4 L7,4" />
                                    </Canvas>
                                </Button>
                                <Button Background="#FF5F57"
                                        BorderBrush="#D94942"
                                        Click="CloseButton_Click"
                                        ToolTip="Close"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#34110F"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1.3,1.3 L6.7,6.7 M6.7,1.3 L1.3,6.7" />
                                    </Canvas>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="18,18,18,0">
                        <Grid Visibility="{Binding ShowLocationStep, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource BadgeBrush}"
                                    BorderBrush="{StaticResource BadgeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentOrangeBrush}"
                                           Text="STEP 1 OF 3" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0,16,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Choose an install folder"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="AudioBit defaults to your local Programs folder. Change it only if you want a custom path."
                                       TextWrapping="Wrap" />

                            <StackPanel Grid.Row="3"
                                        Margin="0,20,0,0">
                                <Border Padding="18"
                                        Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Text="{Binding InstallPathBadgeText}" />
                                        <Border Margin="0,14,0,0"
                                                Padding="15,13"
                                                Background="#20131A23"
                                                BorderBrush="{StaticResource CardBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="17">
                                            <TextBox Style="{StaticResource PathTextBoxStyle}"
                                                     IsEnabled="{Binding CanInstall}"
                                                     Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" />
                                        </Border>
                                        <TextBlock Margin="0,14,0,0"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding ModeSubtitle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="18"
                                        Style="{StaticResource SoftCardStyle}">
                                    <StackPanel>
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   Text="{Binding PhaseText}" />
                                        <TextBlock Margin="0,9,0,0"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding StatusText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <UniformGrid Margin="0,16,0,0"
                                             Columns="2">
                                    <Border Margin="0,0,8,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Per-user install. No admin prompt required."
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <Border Margin="8,0,0,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="Registers AudioBit and leaves a themed uninstaller behind."
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Grid>

                        <Grid Visibility="{Binding ShowOptionsStep, Converter={StaticResource BoolToVisibility}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource BadgeBrush}"
                                    BorderBrush="{StaticResource BadgeBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999">
                                <TextBlock FontSize="10.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentOrangeBrush}"
                                           Text="STEP 2 OF 3" />
                            </Border>

                            <TextBlock Grid.Row="1"
                                       Margin="0,16,0,0"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Text="Choose setup options"
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Pick the shortcuts and pins setup should create after the files are installed."
                                       TextWrapping="Wrap" />

                            <ScrollViewer Grid.Row="3"
                                          Margin="0,20,2,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,0,4,8">
                                    <Border Padding="18"
                                            Style="{StaticResource SoftCardStyle}">
                                        <StackPanel>
                                            <TextBlock FontSize="10.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       Text="INSTALL TARGET" />
                                            <TextBlock Margin="0,9,0,0"
                                                       FontSize="12.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       Text="{Binding InstallPath}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,12,0,0"
                                                       FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="{Binding SetupSummaryText}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,16,0,0">
                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding CreateStartMenuShortcut}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Create Start menu shortcut" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Adds AudioBit and its uninstaller to the Start menu folder."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding CreateDesktopShortcut}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Create desktop shortcut" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Drops a direct launcher on the current user's desktop."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding PinToStart}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Pin AudioBit to Start" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Requests a Start pin using the installed shortcut."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding PinToTaskbar}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Pin AudioBit to the taskbar" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Requests a taskbar pin from the installed executable."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>

                                        <CheckBox Style="{StaticResource OptionCheckBoxStyle}"
                                                  IsChecked="{Binding LaunchAfterInstall}"
                                                  IsEnabled="{Binding CanInstall}">
                                            <Grid>
                                                <TextBlock FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           Text="Launch AudioBit after install" />
                                                <TextBlock Margin="0,20,0,0"
                                                           FontSize="11.5"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="Opens AudioBit as soon as setup finishes successfully."
                                                           TextWrapping="Wrap" />
                                            </Grid>
                                        </CheckBox>
                                    </StackPanel>

                                    <Border Margin="0,8,0,0"
                                            Padding="15"
                                            Style="{StaticResource SoftCardStyle}"
                                            Visibility="{Binding ShowPinningNote, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Text="{Binding PinningNoteText}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="18,18,18,0"
                          Visibility="{Binding ShowProgressStep, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Padding="10,5"
                                HorizontalAlignment="Left"
                                Background="{StaticResource BadgeBrush}"
                                BorderBrush="{StaticResource BadgeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="999">
                            <TextBlock FontSize="10.5"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentOrangeBrush}"
                                       Text="{Binding ProgressStepTag}" />
                        </Border>

                        <TextBlock Grid.Row="1"
                                   Margin="0,16,0,0"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Text="{Binding ProgressTitleText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,8,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Text="{Binding StatusText}"
                                   TextWrapping="Wrap" />

                        <Border Grid.Row="3"
                                Margin="0,20,0,0"
                                Padding="20"
                                Style="{StaticResource SoftCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Width="54"
                                            Height="54"
                                            Background="#2C1E15"
                                            BorderBrush="#7E5434"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Viewbox Width="28"
                                                 Height="28"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="32" Height="32">
                                                <Path Stroke="{StaticResource AccentOrangeBrush}"
                                                      StrokeThickness="3.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="14,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentOrangeBrush}"
                                                   Text="{Binding PhaseText}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Text="{Binding ProgressPercentText}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1"
                                      Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Text="{Binding ProgressBarLabelText}" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="11.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ProgressPercentText}" />
                                </Grid>

                                <Grid Grid.Row="2"
                                      Height="12"
                                      Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding ProgressValue, Converter={StaticResource ProgressToGridLengthConverter}}" />
                                        <ColumnDefinition Width="{Binding RemainingProgressValue, Converter={StaticResource ProgressToGridLengthConverter}}" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.ColumnSpan="2"
                                            Background="#21161E27"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="999" />
                                    <Border Grid.Column="0"
                                            Background="{StaticResource PrimaryButtonBrush}"
                                            CornerRadius="999" />
                                </Grid>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Margin="0,16,0,0">
                            <Border Padding="18"
                                    Style="{StaticResource SoftCardStyle}">
                                <StackPanel>
                                    <TextBlock FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Text="{Binding PathSectionTitle}" />
                                    <TextBlock Margin="0,9,0,0"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding InstallPath}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <UniformGrid Margin="0,14,0,0"
                                         Columns="2">
                                <Border Margin="0,0,8,0"
                                        Padding="15"
                                        Style="{StaticResource SoftCardStyle}">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding PayloadSummaryText}"
                                               TextWrapping="Wrap" />
                                </Border>
                                <Border Margin="8,0,0,0"
                                        Padding="15"
                                        Style="{StaticResource SoftCardStyle}">
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Text="{Binding ModeSummaryText}"
                                               TextWrapping="Wrap" />
                                </Border>
                            </UniformGrid>

                            <Border Margin="0,14,0,0"
                                    Padding="15"
                                    Style="{StaticResource SoftCardStyle}"
                                    Visibility="{Binding IsInstallMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock FontSize="11.5"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Text="{Binding SetupSummaryText}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>

                                <Border Grid.Row="2"
                                        Margin="18,16,18,18"
                                        Padding="14"
                                        Background="{StaticResource FooterBackgroundBrush}"
                                        BorderBrush="{StaticResource FooterBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Grid>
                                        <Grid Visibility="{Binding ShowLocationStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Default folder first, then continue into setup options."
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BrowsePathButton_Click"
                                                        Content="Change folder"
                                                        IsEnabled="{Binding CanInstall}" />
                                                <Button Grid.Column="2"
                                                        MinWidth="110"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="ProceedButton_Click"
                                                        Content="Proceed"
                                                        IsEnabled="{Binding CanProceedFromLocation}" />
                                            </Grid>
                                        </Grid>

                                        <Grid Visibility="{Binding ShowOptionsStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Review the extras, then start the install."
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BackButton_Click"
                                                        Content="Back"
                                                        IsEnabled="{Binding CanInstall}" />
                                                <Button Grid.Column="2"
                                                        MinWidth="134"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Click="InstallButton_Click"
                                                        Content="{Binding InstallButtonText}"
                                                        IsEnabled="{Binding CanRunPrimaryAction}" />
                                            </Grid>
                                        </Grid>

                                        <Grid Visibility="{Binding ShowProgressStep, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock FontSize="11.5"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Text="Portable publish output stays next to the release package."
                                                       TextWrapping="Wrap" />

                                            <Grid Grid.Row="1"
                                                  Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Click="BackButton_Click"
                                                        Content="Back"
                                                        Visibility="{Binding ShowReturnToOptionsButton, Converter={StaticResource BoolToVisibility}}" />

                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                                            Click="LaunchButton_Click"
                                                            Content="Launch AudioBit"
                                                            Visibility="{Binding ShowLaunchButton, Converter={StaticResource BoolToVisibility}}" />
                                                    <Button Margin="10,0,0,0"
                                                            MinWidth="118"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            Click="InstallButton_Click"
                                                            Content="{Binding InstallButtonText}"
                                                            IsEnabled="{Binding CanRunPrimaryAction}" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
    </Grid>
</Window>
