<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#121212</Color>
    <Color x:Key="WindowSurfaceColor">#171717</Color>
    <Color x:Key="PanelBackgroundColor">#1E1E1E</Color>
    <Color x:Key="PanelBorderColor">#2C2C2C</Color>
    <Color x:Key="PanelHoverColor">#252525</Color>
    <Color x:Key="AccentColor">#4CAF50</Color>
    <Color x:Key="AccentLightColor">#6FD675</Color>
    <Color x:Key="AccentSecondaryColor">#00D1FF</Color>
    <Color x:Key="TextPrimaryColor">#F5F5F5</Color>
    <Color x:Key="TextSecondaryColor">#A7A7A7</Color>
    <Color x:Key="TextTertiaryColor">#7A7A7A</Color>
    <Color x:Key="MeterTrackColor">#2D2D2D</Color>
    <Color x:Key="SliderInactiveColor">#3A3A3A</Color>
    <Color x:Key="HoverOverlayColor">#18FFFFFF</Color>
    <Color x:Key="CardHighlightColor">#10FFFFFF</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="WindowSurfaceBrush" Color="{StaticResource WindowSurfaceColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="PanelHoverBrush" Color="{StaticResource PanelHoverColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />
    <SolidColorBrush x:Key="SecondaryAccentBrush" Color="{StaticResource AccentSecondaryColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="MeterTrackBrush" Color="{StaticResource MeterTrackColor}" />
    <SolidColorBrush x:Key="SliderInactiveBrush" Color="{StaticResource SliderInactiveColor}" />
    <SolidColorBrush x:Key="HoverOverlayBrush" Color="{StaticResource HoverOverlayColor}" />
    <SolidColorBrush x:Key="CardHighlightBrush" Color="{StaticResource CardHighlightColor}" />

    <LinearGradientBrush x:Key="MeterFillBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Offset="0" Color="{StaticResource AccentSecondaryColor}" />
        <GradientStop Offset="0.65" Color="{StaticResource AccentColor}" />
        <GradientStop Offset="1" Color="{StaticResource AccentLightColor}" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WindowTopBarBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#1B1B1B" />
        <GradientStop Offset="1" Color="#151515" />
    </LinearGradientBrush>
</ResourceDictionary>
