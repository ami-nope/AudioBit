    <DrawingImage x:Key="SpotifyLogoImage">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#1ED760">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="12,12" RadiusX="12" RadiusY="12" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#121212"
                             Thickness="1.85"
                             StartLineCap="Round"
                             EndLineCap="Round"
                             LineJoin="Round" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M5.1,9.4 C9.4,7.9 14.8,8.2 18.9,10.6" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#121212"
                             Thickness="1.75"
                             StartLineCap="Round"
                             EndLineCap="Round"
