<UserControl x:Class="AudioBit.UI.AudioMeterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:infra="clr-namespace:AudioBit.UI.Infrastructure"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="RootControl"
             d:DesignHeight="82"
             d:DesignWidth="320"
             Stylus.IsFlicksEnabled="False"
             Stylus.IsPressAndHoldEnabled="False"
             Stylus.IsTapFeedbackEnabled="False"
             Stylus.IsTouchFeedbackEnabled="False"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SliderBarButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Grid Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border Height="5"
                                    MinHeight="6"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="2.5" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Grid Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border Width="16"
                                    Height="16"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SliderThumbBrush}"
                                    BorderBrush="{DynamicResource SliderThumbBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{Binding AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Background="{TemplateBinding Background}"
                              SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{TemplateBinding Foreground}"
                                                  Command="Slider.DecreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="{DynamicResource SliderInactiveBrush}"
                                                  Command="Slider.IncreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionMutePillStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource MutePillBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MutePillBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Viewbox Width="13"
                                     Height="13"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid>
                                    <Canvas x:Name="SpeakerIcon" Width="24" Height="24">
                                        <Path Fill="{DynamicResource IconSecondaryBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15,9 C17,10.5 17,13.5 15,15" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M17.5,6.5 C21,9.2 21,14.8 17.5,17.5" />
                                    </Canvas>
                                    <Canvas x:Name="MuteIcon" Width="24" Height="24" Opacity="0">
                                        <Path Fill="{DynamicResource AccentOrangeBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource AccentOrangeBrush}"
                                              StrokeThickness="2.1"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15.5,8.5 L20.5,15.5 M20.5,8.5 L15.5,15.5" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MutePillHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MutePillActiveBackgroundBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource MutePillActiveBorderBrush}" />
                                <Setter TargetName="SpeakerIcon" Property="Opacity" Value="0" />
                                <Setter TargetName="MuteIcon" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionPinOrbToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid x:Name="RootGrid"
                              RenderTransformOrigin="0.5,0.5">
                            <Ellipse x:Name="Halo"
                                     Width="20"
                                     Height="20"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource UtilityButtonBrush}"
                                     Stroke="{DynamicResource UtilityButtonBorderBrush}"
                                     StrokeThickness="1"
                                     Opacity="0.94" />

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Halo" Property="Fill" Value="{DynamicResource UtilityButtonHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Halo" Property="Fill" Value="#28FF8D33" />
                                <Setter TargetName="Halo" Property="Stroke" Value="{DynamicResource AccentOrangeBrush}" />
                                <Setter TargetName="Halo" Property="Opacity" Value="1" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Halo" Property="Fill" Value="#34FF9947" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootGrid" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpectrumBarStyle" TargetType="{x:Type Border}">
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="CornerRadius" Value="2.5" />
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="RenderTransformOrigin" Value="0.5,1" />
        </Style>

        <DataTemplate x:Key="RouteDeviceTemplate">
            <TextBlock FontSize="10.5"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       LineHeight="12"
                       Text="{Binding DisplayName}"
                       TextTrimming="CharacterEllipsis" />
        </DataTemplate>

        <Style x:Key="RouteLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="RouteComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Margin="3,2"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ContextMenuHoverBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource OverlayOptionBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RouteComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource MutePillBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,5,24,5" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MaxDropDownHeight" Value="220" />
            <Setter Property="ItemTemplate" Value="{StaticResource RouteDeviceTemplate}" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource RouteComboBoxItemStyle}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Tag" Value="{Binding IsLowPerformanceMode, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="ControlRoot" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Border x:Name="OuterBorder"
                                    IsHitTestVisible="False"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="13">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Stretch"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      IsHitTestVisible="False" />

                                    <Path x:Name="Arrow"
                                          Width="10"
                                          Height="6"
                                          Margin="0,0,9,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M1,1 L5,5 L9,1"
                                          Stroke="{DynamicResource IconSecondaryBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ControlRoot}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, ElementName=ControlRoot}"
                                        Background="{DynamicResource ContextMenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource ContextMenuBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="24">
                                    <ScrollViewer x:Name="DropDownScrollHost"
                                                  Margin="4"
                                                  CanContentScroll="False"
                                                  PanningMode="VerticalFirst"
                                                  PanningDeceleration="0.001"
                                                  infra:SmoothScrollBehavior.IsEnabled="True"
                                                  infra:SmoothScrollBehavior.SmoothingDuration="250"
                                                  infra:SmoothScrollBehavior.WheelStep="11"
                                                  KeyboardNavigation.DirectionalNavigation="Contained">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource MutePillHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ContextMenuBackgroundBrush}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource AccentOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="PART_Popup" Property="PopupAnimation" Value="None" />
                                <Setter TargetName="DropDownScrollHost" Property="infra:SmoothScrollBehavior.IsEnabled" Value="False" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource SliderInactiveBrush}" />
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Loaded="RootGrid_OnLoaded">
        <Border x:Name="CardBorder"
                Margin="0,1,0,5"
                Background="Transparent"
                MouseEnter="CardBorder_OnMouseEnter"
                MouseLeave="CardBorder_OnMouseLeave"
                CornerRadius="30"
                Opacity="1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardTranslateTransform" Y="0" />
            </Border.RenderTransform>

            <Grid>
                <Border x:Name="CardSurface"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="30" />

                <Border x:Name="CardSheen"
                        Margin="1"
                        Background="{Binding AccentBrush}"
                        CornerRadius="29"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <Border.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#C0FFFFFF" />
                            <GradientStop Offset="0.55" Color="#55FFFFFF" />
                            <GradientStop Offset="1" Color="#00FFFFFF" />
                        </LinearGradientBrush>
                    </Border.OpacityMask>
                </Border>

                <Border x:Name="CardHoverStroke"
                        BorderBrush="{Binding AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="30"
                        IsHitTestVisible="False"
                        Opacity="0" />

                <ToggleButton Width="24"
                              Height="24"
                              Margin="0,-2,-2,0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              IsChecked="{Binding IsPinned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource SessionPinOrbToggleStyle}"
                              ToolTip="{Binding PinToolTip}">
                    <Grid Width="14"
                          Height="14"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform Angle="-18" />
                        </Grid.RenderTransform>
                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              Data="M6.2,3.3 L11.8,3.3 L13.3,6.8 L9,10.3 L4.7,6.8 Z" />
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M9,10.2 L9,15" />
                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                              StrokeThickness="1.3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M6.3,6.2 L11.7,6.2" />
                    </Grid>
                </ToggleButton>

                <Grid Margin="10,7,10,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                        <Border Width="32"
                                Height="32"
                                Background="{DynamicResource IconTileBrush}"
                                BorderBrush="{DynamicResource IconTileBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Image Width="18"
                                   Height="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="{Binding Icon}"
                                   Stretch="Uniform" />
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="10,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding AppName}"
                                   TextTrimming="CharacterEllipsis" />

                        <ToggleButton Grid.Column="2"
                                      Width="24"
                                      Height="24"
                                      Margin="0,1,6,0"
                                      VerticalAlignment="Top"
                                      IsChecked="{Binding IsPinned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource SessionPinOrbToggleStyle}"
                                      ToolTip="{Binding PinToolTip}">
                            <Grid Width="14"
                                  Height="14"
                                  RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform Angle="-18" />
                                </Grid.RenderTransform>
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      Data="M6.2,3.3 L11.8,3.3 L13.3,6.8 L9,10.3 L4.7,6.8 Z" />
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M9,10.2 L9,15" />
                                <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="M6.3,6.2 L11.7,6.2" />
                            </Grid>
                        </ToggleButton>

                        <ToggleButton Grid.Column="3"
                                      Margin="0,1,0,0"
                                      VerticalAlignment="Top"
                                      IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                      Style="{StaticResource SessionMutePillStyle}" />
                    </Grid>

                    <Grid Grid.Row="1"
                          Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Margin="0,0,6,0"
                              VerticalAlignment="Top">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid VerticalAlignment="Top">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid x:Name="MeterPanel"
                                      Height="22"
                                      HorizontalAlignment="Stretch">
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding ShouldShowMeter}" Value="True" />
                                                        <Condition Binding="{Binding IsLowPerformanceMode, ElementName=RootControl}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Border Height="1"
                                            Margin="0,0,0,1"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource DividerBrush}"
                                            Opacity="0.4" />

                                    <UniformGrid Columns="14"
                                                 Margin="0,0,-1,1"
                                                 Rows="1"
                                                 VerticalAlignment="Bottom">
                                        <Border Height="6"
                                                Background="#7160FF"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale01" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="9"
                                                Background="#845DFF"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale02" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="13"
                                                Background="#9757FF"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale03" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="18"
                                                Background="#B44BFF"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale04" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="23"
                                                Background="#D841FF"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale05" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="16"
                                                Background="#F13AEE"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale06" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="28"
                                                Background="#FF3ED4"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale07" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="34"
                                                Background="#FF46B5"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale08" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="19"
                                                Background="#FF4F9B"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale09" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="28"
                                                Background="#FF5C86"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale10" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="16"
                                                Background="#FF6A74"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale11" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="23"
                                                Background="#FF7B63"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale12" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="13"
                                                Background="#FF8D53"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale13" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                        <Border Height="20"
                                                Margin="0"
                                                Background="#FFA140"
                                                Style="{StaticResource SpectrumBarStyle}">
                                            <Border.RenderTransform><ScaleTransform x:Name="BarScale14" ScaleY="0.18" /></Border.RenderTransform>
                                        </Border>
                                    </UniformGrid>
                                </Grid>

                                <Grid x:Name="StaticMeterPanel"
                                      Height="22"
                                      HorizontalAlignment="Stretch">
                                    <Grid.Style>
                                        <Style TargetType="{x:Type Grid}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLowPerformanceMode, ElementName=RootControl}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <Border Height="1"
                                            Margin="0,0,0,1"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource DividerBrush}"
                                            Opacity="0.65" />

                                    <UniformGrid Columns="14"
                                                 Margin="0,0,-1,1"
                                                 Rows="1"
                                                 VerticalAlignment="Bottom">
                                        <Border Height="5" Background="#7160FF" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="8" Background="#845DFF" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="10" Background="#9757FF" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="14" Background="#B44BFF" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="18" Background="#D841FF" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="12" Background="#F13AEE" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="22" Background="#FF3ED4" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="26" Background="#FF46B5" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="15" Background="#FF4F9B" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="21" Background="#FF5C86" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="12" Background="#FF6A74" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="17" Background="#FF7B63" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="10" Background="#FF8D53" Style="{StaticResource SpectrumBarStyle}" />
                                        <Border Height="15" Margin="0" Background="#FFA140" Style="{StaticResource SpectrumBarStyle}" />
                                    </UniformGrid>
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Margin="0,3,0,0"
                                           FontSize="10.5"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           LineHeight="12"
                                           Text="{Binding RecentActivityText}"
                                           TextTrimming="CharacterEllipsis">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding HasRecentActivityText}" Value="True" />
                                                        <Condition Binding="{Binding IsLowPerformanceMode, ElementName=RootControl}" Value="False" />
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <Grid Grid.Row="1"
                                  Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Slider Minimum="0"
                                        Maximum="1"
                                        IsMoveToPointEnabled="True"
                                        LargeChange="{Binding DataContext.VolumeStepValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                        PreviewMouseWheel="VolumeSlider_OnPreviewMouseWheel"
                                        SmallChange="{Binding DataContext.VolumeStepValue, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource CardSliderStyle}"
                                        Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Column="1"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding VolumePercentText}" />
                            </Grid>
                        </Grid>

                        <StackPanel Grid.Column="1"
                                    Margin="6,0,0,0"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch">
                            <StackPanel Margin="0,0,0,2"
                                        Orientation="Horizontal">
                                <Viewbox Width="9"
                                         Height="9"
                                         VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource IconSecondaryBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15,9 C17,10.5 17,13.5 15,15" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M17.5,6.5 C21,9.2 21,14.8 17.5,17.5" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Style="{StaticResource RouteLabelStyle}"
                                           Text="Speaker" />
                            </StackPanel>

                            <ComboBox Margin="0,0,0,6"
                                      IsEnabled="{Binding CanRouteDevices}"
                                      ItemsSource="{Binding PlaybackDevices}"
                                      SelectedValue="{Binding SelectedPlaybackDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id"
                                      Style="{StaticResource RouteComboBoxStyle}" />

                            <StackPanel Margin="0,0,0,2"
                                        Orientation="Horizontal">
                                <Viewbox Width="9"
                                         Height="9"
                                         VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{DynamicResource IconSecondaryBrush}"
                                              Data="M12,3 C9.5,3 7.5,5 7.5,7.5 V12.2 C7.5,14.7 9.5,16.7 12,16.7 C14.5,16.7 16.5,14.7 16.5,12.2 V7.5 C16.5,5 14.5,3 12,3 Z" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              Data="M5.5,11.5 C5.5,15.1 8.4,18 12,18 C15.6,18 18.5,15.1 18.5,11.5 M12,18 L12,21 M8.8,21 L15.2,21" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Style="{StaticResource RouteLabelStyle}"
                                           Text="Mic" />
                            </StackPanel>

                            <ComboBox Margin="0,0,0,0"
                                      IsEnabled="{Binding CanRouteDevices}"
                                      ItemsSource="{Binding CaptureDevices}"
                                      SelectedValue="{Binding SelectedCaptureDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="Id"
                                      Style="{StaticResource RouteComboBoxStyle}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
