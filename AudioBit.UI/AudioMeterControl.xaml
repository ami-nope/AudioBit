<UserControl x:Class="AudioBit.UI.AudioMeterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="108"
             d:DesignWidth="320"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="SliderBarButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="7"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="18"
                                Height="18"
                                Background="{DynamicResource SliderThumbBrush}"
                                BorderBrush="{DynamicResource SliderThumbBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{Binding AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Margin="0,7,0,0">
                            <Track x:Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{TemplateBinding Foreground}"
                                                  Command="Slider.DecreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="{DynamicResource SliderInactiveBrush}"
                                                  Command="Slider.IncreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionMutePillStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource MutePillBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource MutePillBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Viewbox Width="16"
                                     Height="16"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid>
                                    <Canvas x:Name="SpeakerIcon" Width="24" Height="24">
                                        <Path Fill="{DynamicResource IconSecondaryBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15,9 C17,10.5 17,13.5 15,15" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M17.5,6.5 C21,9.2 21,14.8 17.5,17.5" />
                                    </Canvas>
                                    <Canvas x:Name="MuteIcon" Width="24" Height="24" Opacity="0">
                                        <Path Fill="{DynamicResource AccentOrangeBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource AccentOrangeBrush}"
                                              StrokeThickness="2.1"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15.5,8.5 L20.5,15.5 M20.5,8.5 L15.5,15.5" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MutePillHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource MutePillActiveBackgroundBrush}" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource MutePillActiveBorderBrush}" />
                                <Setter TargetName="SpeakerIcon" Property="Opacity" Value="0" />
                                <Setter TargetName="MuteIcon" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Loaded="RootGrid_OnLoaded"
          SizeChanged="RootGrid_OnSizeChanged"
          MouseEnter="RootGrid_OnMouseEnter"
          MouseLeave="RootGrid_OnMouseLeave">
        <Border x:Name="CardBorder"
                Margin="0,0,0,12"
                Padding="14,14,14,12"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardTranslateTransform" Y="10" />
            </Border.RenderTransform>

            <Grid>
                <Border x:Name="HoverOverlay"
                        Background="{DynamicResource CardHoverOverlayBrush}"
                        CornerRadius="20"
                        Opacity="0" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="38"
                                Height="38"
                                Background="{DynamicResource IconTileBrush}"
                                BorderBrush="{DynamicResource IconTileBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Image Width="22"
                                   Height="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Source="{Binding Icon}"
                                   Stretch="Uniform" />
                        </Border>

                        <TextBlock Grid.Column="1"
                                   Margin="12,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding AppName}"
                                   TextTrimming="CharacterEllipsis" />

                        <ToggleButton Grid.Column="2"
                                      VerticalAlignment="Top"
                                      IsChecked="{Binding IsMuted, Mode=TwoWay}"
                                      Style="{StaticResource SessionMutePillStyle}" />
                    </Grid>

                    <Border Grid.Row="1"
                            Height="3"
                            Margin="0,12,0,0"
                            HorizontalAlignment="Left"
                            Width="74"
                            Background="{Binding AccentBrush}"
                            CornerRadius="2"
                            Opacity="0.75" />

                    <Grid Grid.Row="1"
                          Margin="0,20,0,0">
                        <Grid x:Name="MeterPanel">
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Border Width="5" Height="10" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale01" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="14" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale02" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="18" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale03" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="22" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale04" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="17" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale05" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="24" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale06" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="15" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale07" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="20" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale08" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="14" Margin="0,0,4,0" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale09" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                                <Border Width="5" Height="9" Background="{Binding AccentBrush}" CornerRadius="1.5" RenderTransformOrigin="0.5,1">
                                    <Border.RenderTransform><ScaleTransform x:Name="BarScale10" ScaleY="0.18" /></Border.RenderTransform>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding RecentActivityText}"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRecentActivityText}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Grid Grid.Row="2"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Slider Minimum="0"
                                Maximum="1"
                                IsMoveToPointEnabled="True"
                                Style="{StaticResource CardSliderStyle}"
                                Value="{Binding Volume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Column="1"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="{Binding VolumePercentText}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
