                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="DisconnectBorder" Property="Opacity" Value="0.94" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="DisconnectBorder" Property="Opacity" Value="0.88" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                                <Canvas Width="15" Height="15" VerticalAlignment="Center">
                                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M9.5,2.2 L5.5,2.2 C4.1,2.2 3,3.3 3,4.7 L3,10.3 C3,11.7 4.1,12.8 5.5,12.8 L9.5,12.8" />
                                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="1.8"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M8.2,7.5 L13.2,7.5 M11.2,5.2 L13.2,7.5 L11.2,9.8" />
                                                </Canvas>
