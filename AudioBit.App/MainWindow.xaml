                                                               VerticalAlignment="Center"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Text="Reveal SID &amp; Pair-Code" />
                                                </StackPanel>
                                            </Button>

                                        </StackPanel>

                                        <StackPanel Visibility="{Binding IsRemoteSidCredentialsViewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
