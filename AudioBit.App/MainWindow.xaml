                                                    <Rectangle Width="74"
                                                               Height="14"
                                                               HorizontalAlignment="Left"
                                                               Fill="#3A4168"
                                                               RadiusX="4"
                                                               RadiusY="4" />
                                                    <Rectangle Margin="0,12,0,0"
                                                               Width="180"
                                                               Height="14"
                                                               HorizontalAlignment="Left"
                                                               Fill="#31385E"
                                                               RadiusX="4"
                                                               RadiusY="4" />
                                                    <Rectangle Margin="0,10,0,0"
                                                               Width="74"
                                                               Height="14"
                                                               HorizontalAlignment="Left"
                                                               Fill="#3A4168"
                                                               RadiusX="4"
                                                               RadiusY="4" />
