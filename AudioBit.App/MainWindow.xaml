                                                    <ImageBrush ImageSource="{Binding RemoteQrCodeImage}"
                                                                Stretch="Uniform"
                                                                AlignmentX="Center"
                                                                AlignmentY="Center"
                                                                RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                </Rectangle.Fill>
                                            </Rectangle>
                                        </Border>
                                    </Button>

                                    <TextBlock Margin="0,9,0,0"
                                               FontSize="11"
                                               Foreground="#666880"
                                               Visibility="{Binding IsRemoteQrPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                               Text="Scan with AudioBit Mobile to connect"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,10,0,0"
                                          Visibility="{Binding IsRemoteQrPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
