                                                    <TextBlock FontSize="11.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="#E7EBFF"
                                                               Text="Connected Devices" />

                                                    <Border Grid.Row="1"
                                                            Margin="0,8,0,0"
                                                            Padding="8,7,8,7"
