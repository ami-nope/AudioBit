                                                Background="#2A1700"
                                                BorderBrush="#A35A00"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock FontSize="13.5"
                                                           Foreground="#DCA66A"
                                                           Text="Session Policy" />
                                                    <TextBlock Grid.Column="1"
                                                               FontSize="13.5"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Text="No timeout" />
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,8,0,0"
                                                Padding="14,12,14,12"
                                                Background="#2A2E4A"
                                                BorderBrush="#373F63"
                                                BorderThickness="1"
                                                CornerRadius="16">
