                                  HorizontalScrollBarVisibility="Disabled"
                                  PanningMode="VerticalFirst"
                                  PanningDeceleration="0.001"
                                  infra:SmoothScrollBehavior.IsEnabled="{Binding EnableEnhancedVisuals}"
                                  infra:SmoothScrollBehavior.SmoothingDuration="300"
                                  infra:SmoothScrollBehavior.WheelStep="9"
                                  Visibility="{Binding IsSettingsTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                        </ScrollViewer.Resources>

                        <StackPanel x:Name="SettingsStackHost"
                                    Margin="0,0,0,10">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="GENERAL"
                                       TextTrimming="CharacterEllipsis" />

                            <Border Margin="0,10,0,0"
                                    Padding="14,6,14,6"
                                    Style="{StaticResource SettingsSectionCardStyle}">
                                <StackPanel>
                                    <Grid Margin="0,6,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M12,4 L12,11 M7,6.5 C4.8,8.1 3.5,10.4 3.5,13 C3.5,17.7 7.3,21.5 12,21.5 C16.7,21.5 20.5,17.7 20.5,13 C20.5,10.4 19.2,8.1 17,6.5" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Open on Startup" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Launch AudioBit when Windows starts." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding OpenOnStartup, Mode=TwoWay}" Style="{StaticResource SettingsToggleStyle}" />
                                    </Grid>


                                    <Grid Margin="0,12,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M5,16 L19,16 M7,10 L17,10" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Minimise to Tray" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Keep the app available from the system tray." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding HideToTrayOnMinimize, Mode=TwoWay}" Style="{StaticResource SettingsToggleStyle}" />
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                    <StackPanel Margin="0,12,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Rectangle Width="14" Height="10" Canvas.Left="5" Canvas.Top="6" RadiusX="2" RadiusY="2" Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.5" />
