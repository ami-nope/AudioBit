                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="Mixer Core" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Default live monitor" />
                                            </StackPanel>
                                        </Button>

                                        <Button Tag="device-watch"
                                                Command="{Binding SelectAgentCommand}"
                                                CommandParameter="device-watch"
                                                Style="{StaticResource AgentOptionButtonStyle}">
                                            <StackPanel>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="Device Watch" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Track output route changes" />
                                            </StackPanel>
                                        </Button>

                                        <Button Tag="quiet-night"
                                                Command="{Binding SelectAgentCommand}"
                                                CommandParameter="quiet-night"
                                                Style="{StaticResource AgentOptionButtonStyle}">
                                            <StackPanel>
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="Quiet Night" />
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Softer evening profile" />
                                            </StackPanel>
                                        </Button>

                                        <Border Margin="0,8,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Selected profile" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding SelectedAgentName}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding SelectedAgentSummary}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

