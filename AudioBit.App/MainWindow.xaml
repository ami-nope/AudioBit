                                                            Command="{Binding CopyRemoteSessionIdCommand}"
                                                            Style="{StaticResource RemoteCopyButtonStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Canvas Width="13" Height="13" VerticalAlignment="Center">
                                                                <Rectangle Width="7" Height="7" RadiusX="1" RadiusY="1" StrokeThickness="1.1" Stroke="#A9B0D8" Canvas.Left="1.2" Canvas.Top="1.2" />
                                                                <Rectangle Width="7" Height="7" RadiusX="1" RadiusY="1" StrokeThickness="1.1" Stroke="#A9B0D8" Canvas.Left="4.5" Canvas.Top="4.5" />
                                                            </Canvas>
                                                            <TextBlock Margin="6,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Text="Copy" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12.5"
                                                           Foreground="#7C86B0"
                                                           Text="Unique session identifier"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsRemoteQrPanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Margin="0,4,0,0">
