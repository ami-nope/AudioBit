                                                               TextAlignment="Center" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="11.5"
                                                               Foreground="#6BA2DF"
                                                               Text="{Binding RemoteConnectedSubtitleText}"
                                                               TextAlignment="Center" />
                                                    <Border Margin="0,12,0,0"
                                                            Padding="15,8,15,8"
                                                            Background="#112E1D"
                                                            BorderBrush="#1D6641"
                                                            BorderThickness="1"
                                                            CornerRadius="14">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Canvas Width="14" Height="14" VerticalAlignment="Center">
                                                                <Ellipse Width="12" Height="12" Canvas.Left="1" Canvas.Top="1" Stroke="#36D17A" StrokeThickness="1.5" />
                                                                <Path Stroke="#36D17A"
                                                                      StrokeThickness="1.5"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      Data="M3.5,7 L10.5,7" />
                                                            </Canvas>
                                                            <TextBlock Margin="7,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="11"
                                                                       Foreground="#88B698"
                                                                       Text="One device per session" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Margin="0,10,0,0"
                                                Padding="10,8,10,8"
                                                Background="#2A2E4A"
                                                BorderBrush="#373F63"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="38"
                                                        Height="38"
                                                        Background="#31375A"
                                                        CornerRadius="12">
                                                    <Canvas Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
