                                                                   FontSize="12.5"
                                                                   Foreground="#6B73A2"
                                                                   Text="Credentials hidden for security" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <Button Margin="0,8,0,0"
                                                    Height="40"
