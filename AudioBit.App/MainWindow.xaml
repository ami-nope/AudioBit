                                    Margin="0,0,12,0"
                                    Background="{DynamicResource BrandTileBrush}"
                                    BorderBrush="{DynamicResource BrandTileBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Viewbox Width="30"
                                         Height="30"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Stroke="{DynamicResource BrandGlyphBrush}"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="AudioBit" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Margin="0,2,0,0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <ToggleButton Margin="0,0,8,0"
                                              IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}"
                                              ToolTip="{Binding PinToggleToolTip}"
                                              Visibility="{Binding ShowAlwaysOnTopPin, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Style="{StaticResource PinOrbToggleStyle}">
                                    <Grid Width="18"
                                          Height="18"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <RotateTransform Angle="-18" />
                                        </Grid.RenderTransform>
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                              Data="M6.2,3.3 L11.8,3.3 L13.3,6.8 L9,10.3 L4.7,6.8 Z" />
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                              StrokeThickness="1.45"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M9,10.2 L9,15" />
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                              StrokeThickness="1.45"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M6.3,6.2 L11.7,6.2" />
                                    </Grid>
                                </ToggleButton>

                                <Button Margin="0,0,8,0"
                                        ToolTip="{Binding ThemeToggleToolTip}"
                                        Command="{Binding ToggleThemeCommand}"
                                        Style="{StaticResource ThemeOrbButtonStyle}">
                                    <Grid Width="18" Height="18">
                                        <Grid ClipToBounds="True">
                                            <Grid.Clip>
                                                <EllipseGeometry Center="9,9" RadiusX="8.5" RadiusY="8.5" />
                                            </Grid.Clip>
                                            <Rectangle Width="9"
                                                       HorizontalAlignment="Left"
                                                       Fill="#FFF8F2" />
                                            <Rectangle Width="9"
                                                       HorizontalAlignment="Right"
                                                       Fill="#12141A" />
                                        </Grid>
                                        <Ellipse Width="18"
                                                 Height="18"
                                                 Stroke="#6A6D80"
                                                 StrokeThickness="1" />
                                    </Grid>
                                </Button>

                                <Button Margin="0,0,6,0"
                                        Background="#2DCB5A"
                                        BorderBrush="#1D9440"
                                        Click="MinimizeWindow_OnClick"
                                        ToolTip="Minimize"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#0F2817"
                                              StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1,4 L7,4" />
                                    </Canvas>
                                </Button>

                                <Button Background="#FF5F57"
                                        BorderBrush="#D94942"
                                        Click="CloseWindow_OnClick"
                                        ToolTip="Close"
                                        Style="{StaticResource TrafficButtonStyle}">
                                    <Canvas Width="8" Height="8">
                                        <Path Stroke="#34110F"
                                              StrokeThickness="1.3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M1.3,1.3 L6.7,6.7 M6.7,1.3 L1.3,6.7" />
                                    </Canvas>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1"
                          Margin="14,12,14,0">
                        <Border x:Name="MasterCardHost"
                                Background="Transparent"
                                MouseEnter="MasterCardHost_OnMouseEnter"
                                MouseLeave="MasterCardHost_OnMouseLeave"
                                RenderTransformOrigin="0.5,0.5"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="MasterCardLiftTransform" Y="0" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="MasterCardSurface"
                                        Background="{DynamicResource CardBackgroundBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20" />

                                <Border x:Name="MasterCardSheen"
                                        Margin="1"
                                        CornerRadius="19"
                                        IsHitTestVisible="False"
                                        Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#18FFFFFF" Offset="0" />
                                            <GradientStop Color="#10FFB066" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Border x:Name="MasterCardHoverStroke"
                                        BorderBrush="{DynamicResource OverlaySelectedBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        IsHitTestVisible="False"
                                        Opacity="0" />

                                <Grid Margin="16,10,16,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6*" />
                                        <ColumnDefinition Width="4*" />
                                    </Grid.ColumnDefinitions>

                                    <Grid Margin="0,0,12,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock FontSize="15"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="Master Volume" />

                                            <TextBlock Grid.Column="1"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Text="{Binding MasterVolumePercentText}" />
                                        </Grid>

                                        <Grid Grid.Row="1"
                                              Margin="0,8,0,0"
                                              IsEnabled="{Binding HasPlaybackDevice}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Viewbox Width="20"
                                                     Height="20"
                                                     Margin="0,0,10,0"
                                                     VerticalAlignment="Center">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="{DynamicResource IconSecondaryBrush}"
                                                          Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                                    <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                                          StrokeThickness="1.9"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M15,9 C17,10.5 17,13.5 15,15" />
                                                    <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                                          StrokeThickness="1.9"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          Data="M17.5,6.5 C21,9.2 21,14.8 17.5,17.5" />
                                                </Canvas>
                                            </Viewbox>

                                            <Slider Grid.Column="1"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    IsMoveToPointEnabled="True"
                                                    LargeChange="{Binding VolumeStepValue}"
                                                    PreviewMouseWheel="VolumeSlider_OnPreviewMouseWheel"
                                                    SmallChange="{Binding VolumeStepValue}"
                                                    Style="{StaticResource MasterSliderStyle}"
                                                    Value="{Binding MasterVolume, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                            <ToggleButton Grid.Column="2"
                                                          Margin="10,0,0,0"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsMasterMuted, Mode=TwoWay}"
                                                          Style="{StaticResource MasterSpeakerToggleStyle}" />
                                        </Grid>
                                    </Grid>

                                    <Border x:Name="DeviceCardHost"
                                            Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Padding="12,8,12,8"
                                            Background="{DynamicResource OverlayOptionBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <Viewbox Width="18"
                                                     Height="18"
                                                     HorizontalAlignment="Left">
                                                <Canvas Width="28" Height="28">
                                                    <Path Fill="{DynamicResource AccentOrangeBrush}"
                                                          Data="M5,13 C5,8 8.5,4.5 13,4.5 C17.5,4.5 21,8 21,13 L18.5,13 C18.5,9.4 16,7 13,7 C10,7 7.5,9.4 7.5,13 Z" />
                                                    <Rectangle Width="2.6" Height="8" RadiusX="1.2" RadiusY="1.2" Canvas.Left="4" Canvas.Top="14.5" Fill="{DynamicResource AccentOrangeBrush}" />
                                                    <Rectangle Width="2.6" Height="10" RadiusX="1.2" RadiusY="1.2" Canvas.Left="8" Canvas.Top="12.5" Fill="{DynamicResource AccentOrangeBrush}" />
                                                    <Rectangle Width="2.6" Height="6" RadiusX="1.2" RadiusY="1.2" Canvas.Left="12" Canvas.Top="16.5" Fill="{DynamicResource AccentOrangeBrush}" />
                                                    <Rectangle Width="2.6" Height="10" RadiusX="1.2" RadiusY="1.2" Canvas.Left="16" Canvas.Top="12.5" Fill="{DynamicResource AccentOrangeBrush}" />
                                                    <Rectangle Width="2.6" Height="8" RadiusX="1.2" RadiusY="1.2" Canvas.Left="20" Canvas.Top="14.5" Fill="{DynamicResource AccentOrangeBrush}" />
                                                </Canvas>
                                            </Viewbox>

                                            <TextBlock Grid.Row="1"
                                                       Margin="0,6,0,0"
                                                       FontSize="9.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Text="Output Device"
                                                       TextTrimming="CharacterEllipsis" />

                                            <TextBlock Grid.Row="2"
                                                       Margin="0,3,0,0"
                                                       VerticalAlignment="Top"
                                                       FontSize="10.5"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       LineHeight="13"
                                                       Text="{Binding DeviceDisplayName}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="EqContentHost"
                          Grid.Row="3"
                          Grid.RowSpan="2"
                          Visibility="{Binding IsEqTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="MixerSectionHost"
                              Grid.Row="0"
                              Margin="18,2,18,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="APP MIXER" />

                            <Border Grid.Column="1"
                                    Height="1"
                                    Margin="12,10,0,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource DividerBrush}" />
                        </Grid>

                        <Grid x:Name="MixerListHost"
                              Grid.Row="1"
                              Margin="14,0,14,0">
                            <ListBox Padding="0,8,0,4"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.PanningMode="VerticalFirst"
                                      ScrollViewer.PanningDeceleration="0.001"
                                      infra:SmoothScrollBehavior.IsEnabled="{Binding EnableEnhancedVisuals}"
                                      infra:SmoothScrollBehavior.SmoothingDuration="220"
                                      infra:SmoothScrollBehavior.WheelStep="13"
                                      ItemContainerStyle="{StaticResource SessionListBoxItemStyle}"
                                      ItemsSource="{Binding Sessions}"
                                      PreviewMouseLeftButtonDown="MixerListBox_OnPreviewMouseLeftButtonDown"
                                      ScrollViewer.CanContentScroll="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.Resources>
                                    <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                </ListBox.Resources>
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Margin="0,6,0,0" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <abui:AudioMeterControl CardOpacity="{Binding Opacity}"
                                                                IsLowPerformanceMode="{Binding DataContext.IsLowPerformanceMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                PeakValue="{Binding Peak}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="72"
                                            Height="72"
                                            Background="{DynamicResource IconTileBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="22">
                                        <Viewbox Width="34"
                                                 Height="34"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Canvas Width="32" Height="32">
                                                <Path Stroke="{DynamicResource AccentOrangeBrush}"
                                                      StrokeThickness="3.2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <TextBlock Margin="0,18,0,0"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="No active app sessions" />
                                    <TextBlock Margin="0,8,0,0"
                                               Width="220"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Start playback in any app to populate the mixer."
                                               TextAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid x:Name="ProfilesContentHost"
                          Grid.Row="3"
                          Grid.RowSpan="2"
                          Margin="14,2,14,0"
                          Visibility="{Binding IsProfilesTabSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer x:Name="ProfilesContentScrollHost"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      PanningMode="VerticalFirst"
                                      PanningDeceleration="0.001"
                                      infra:SmoothScrollBehavior.IsEnabled="{Binding EnableEnhancedVisuals}"
                                      infra:SmoothScrollBehavior.SmoothingDuration="250"
                                      infra:SmoothScrollBehavior.WheelStep="10">
                            <ScrollViewer.Resources>
                                <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ScrollViewer.Resources>
                            <StackPanel Margin="0,0,0,0">
                            <Border Margin="0,2,0,0"
                                    MinHeight="150"
                                    Padding="12,10,12,10"
                                    Style="{StaticResource SettingsSectionCardStyle}">
                                <Border.Resources>
                                    <Style x:Key="RemoteModeTileButtonStyle" TargetType="{x:Type Button}">
                                        <Setter Property="Background" Value="#2A2E4A" />
                                        <Setter Property="BorderBrush" Value="#3B4060" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="#9EA4CB" />
                                        <Setter Property="Padding" Value="9,7" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="ModeBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="14">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ModeBorder" Property="Opacity" Value="0.96" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="ModeBorder" Property="Opacity" Value="0.9" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                    <Style x:Key="RemoteCopyButtonStyle" TargetType="{x:Type Button}">
                                        <Setter Property="MinWidth" Value="80" />
                                        <Setter Property="Padding" Value="14,8" />
                                        <Setter Property="Background" Value="#383D5C" />
                                        <Setter Property="BorderBrush" Value="#4C537A" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="#E0E4FA" />
                                        <Setter Property="Cursor" Value="Hand" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <Border x:Name="CopyBorder"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="16">
                                                        <ContentPresenter Margin="{TemplateBinding Padding}" 
                                                                          HorizontalAlignment="Center" 
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="CopyBorder" Property="Background" Value="#424869" />
                                                            <Setter TargetName="CopyBorder" Property="BorderBrush" Value="#5C648A" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="CopyBorder" Property="Background" Value="#2D324D" />
                                                            <Setter TargetName="CopyBorder" Property="BorderBrush" Value="#3F4565" />
                                                            <Setter TargetName="CopyBorder" Property="Opacity" Value="0.9" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Border.Resources>
                                <StackPanel>
                                    <StackPanel.LayoutTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1" />
                                    </StackPanel.LayoutTransform>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock FontSize="28"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="RemoteBit" />

                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Visibility="{Binding IsRemoteConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center"
                                                     Fill="#22C55E" />
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#22C55E"
                                                       Text="Connected" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <StackPanel.Style>
                                                <Style TargetType="{x:Type StackPanel}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRemoteConnected}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{DynamicResource AccentOrangeBrush}" />
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentOrangeBrush}"
                                                       Text="Pairing..." />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,6,0,0"
                                          Visibility="{Binding IsRemoteModeMenuVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Command="{Binding SelectRemotePanelModeCommand}"
                                                CommandParameter="qr">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource RemoteModeTileButtonStyle}" TargetType="{x:Type Button}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRemoteQrPanelActive}" Value="True">
                                                            <Setter Property="Background" Value="#2D1A00" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}" />
                                                            <Setter Property="BorderThickness" Value="1.5" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30"
                                                        Height="30"
                                                        CornerRadius="15">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
                                                            <Setter Property="Background" Value="#363B5A" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRemoteQrPanelActive}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentOrangeBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Canvas Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Rectangle Width="5" Height="5" RadiusX="1" RadiusY="1" StrokeThickness="1.2"
                                                                   Canvas.Left="1" Canvas.Top="1"
                                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                        <Rectangle Width="5" Height="5" RadiusX="1" RadiusY="1" StrokeThickness="1.2"
                                                                   Canvas.Left="12" Canvas.Top="1"
                                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                        <Rectangle Width="5" Height="5" RadiusX="1" RadiusY="1" StrokeThickness="1.2"
                                                                   Canvas.Left="1" Canvas.Top="12"
                                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                        <Rectangle Width="5" Height="5" RadiusX="1" RadiusY="1" StrokeThickness="1.2"
                                                                   Canvas.Left="12" Canvas.Top="12"
                                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    </Canvas>
                                                </Border>
                                                <TextBlock Grid.Column="1"
                                                           Margin="8,0,0,0"
                                                           VerticalAlignment="Center"
                                                           FontSize="12.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                           Text="Generate QR" />
                                            </Grid>
                                        </Button>

                                        <Button Grid.Column="2"
                                                Command="{Binding SelectRemotePanelModeCommand}"
                                                CommandParameter="sid">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource RemoteModeTileButtonStyle}" TargetType="{x:Type Button}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRemoteSidPanelActive}" Value="True">
                                                            <Setter Property="Background" Value="#2B103D" />
                                                            <Setter Property="BorderBrush" Value="#A855F7" />
                                                            <Setter Property="BorderThickness" Value="1.5" />
                                                            <Setter Property="Foreground" Value="#D6A1FF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="30"
                                                        Height="30"
                                                        CornerRadius="15">
                                                    <Border.Style>
                                                        <Style TargetType="{x:Type Border}">
