                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock FontSize="13"
                                                               Foreground="#A6ADD2"
                                                               Text="Pair Code" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="12,0,0,0"
                                                                   FontSize="24"
                                                                   FontFamily="Consolas"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   Text="{Binding RemotePairCode}" />
                                                    <Button Grid.Column="2"
                                                            Command="{Binding CopyRemotePairCodeCommand}"
                                                            Style="{StaticResource RemoteCopyButtonStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Canvas Width="13" Height="13" VerticalAlignment="Center">
                                                                <Rectangle Width="7" Height="7" RadiusX="1" RadiusY="1" StrokeThickness="1.1" Stroke="#A9B0D8" Canvas.Left="1.2" Canvas.Top="1.2" />
                                                                <Rectangle Width="7" Height="7" RadiusX="1" RadiusY="1" StrokeThickness="1.1" Stroke="#A9B0D8" Canvas.Left="4.5" Canvas.Top="4.5" />
                                                            </Canvas>
                                                            <TextBlock Margin="6,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Text="Copy" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12.5"
                                                           Foreground="#7C86B0"
                                                           Text="Enter on your remote device to authenticate"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,8,0,0"
                                                Padding="14,12,14,12"
                                                Background="#2A2E4A"
                                                BorderBrush="#373F63"
                                                BorderThickness="1"
                                                CornerRadius="16">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
