                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Calibrated Agents" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Saved profile snapshots" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding CloseOverlayCommand}"
                                            Style="{StaticResource OverlayCloseButtonStyle}">
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="X" />
                                    </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Margin="0,18,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                    </ScrollViewer.Resources>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Keep a compact snapshot of the current profile, device state, and calibration." />

                                        <Border Margin="0,14,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Selected profile" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding SelectedAgentName}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding SelectedAgentSummary}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,12,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Current device" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding DeviceDisplayName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding StatusText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,12,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Calibration snapshot" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding AppliedCalibrationLabel}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding SelectedAgentFootnote}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
