                                                <StackPanel Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               Text="Remote Device" />
                                                    <TextBlock Margin="0,2,0,0"
                                                               FontSize="11.5"
