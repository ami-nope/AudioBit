                                                Height="62"
                                                Background="#252742"
                                                CornerRadius="18">
                                            <Canvas Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Path Stroke="#3A3C55" StrokeThickness="2.1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M3.8,11 C8.8,6.2 21.2,6.2 26.2,11" />
                                                <Path Stroke="#3A3C55" StrokeThickness="2.1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Data="M8.3,15.5 C11.8,12.6 18.2,12.6 21.7,15.5" />
                                                <Ellipse Width="3.2" Height="3.2" Canvas.Left="13.4" Canvas.Top="20.2" Fill="#3A3C55" />
                                            </Canvas>
                                        </Border>
                                        <TextBlock Margin="0,9,0,0"
                                                   FontSize="12"
                                                   Foreground="#666880"
                                                   Text="Select a connection method above to pair your device"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemoteSidPanelVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRemoteConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="Pair Code" />
                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemotePairCode}" />
                                        <Button Grid.Column="2"
                                                Margin="10,0,0,0"
                                                MinWidth="56"
                                                Command="{Binding CopyRemotePairCodeCommand}"
                                                Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="10.5" FontWeight="SemiBold" Text="Copy" />
                                        </Button>
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemoteSidPanelVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRemoteConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
