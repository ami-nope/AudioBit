                                                <ControlTemplate TargetType="{x:Type Button}">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Border Background="#101010"
                                                    BorderBrush="#373F63"
                                                    BorderThickness="1"
                                                    CornerRadius="20"
                                                    ClipToBounds="True">
                                                <Rectangle SnapsToDevicePixels="True">
                                                    <Rectangle.Fill>
                                                        <ImageBrush ImageSource="{Binding RemoteQrCodeImage}"
                                                                    Stretch="Uniform"
                                                                    AlignmentX="Center"
                                                                    AlignmentY="Center"
                                                                    RenderOptions.BitmapScalingMode="NearestNeighbor" />
                                                    </Rectangle.Fill>
                                                </Rectangle>
                                            </Border>
                                        </Button>

