            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid x:Name="ControlRoot" SnapsToDevicePixels="True">
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          ClickMode="Press"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Border x:Name="OuterBorder"
                                    IsHitTestVisible="False"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="17">
                                <Grid>
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      IsHitTestVisible="False" />

                                    <Path x:Name="Arrow"
                                          Width="10"
                                          Height="6"
                                          Margin="0,0,11,0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          Data="M1,1 L5,5 L9,1"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="1.8"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round" />
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=ControlRoot}"
                                   PopupAnimation="{Binding DataContext.SessionPopupAnimation, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, ElementName=ControlRoot}"
                                        Background="{DynamicResource ContextMenuBackgroundBrush}"
                                        BorderBrush="{DynamicResource ContextMenuBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <ScrollViewer Margin="5"
                                                  CanContentScroll="False"
                                                  KeyboardNavigation.DirectionalNavigation="Contained"
                                                  PanningMode="VerticalFirst"
                                                  PanningDeceleration="0.001"
                                                  infra:SmoothScrollBehavior.IsEnabled="{Binding DataContext.EnableEnhancedVisuals, RelativeSource={RelativeSource TemplatedParent}}"
                                                  infra:SmoothScrollBehavior.SmoothingDuration="250"
                                                  infra:SmoothScrollBehavior.WheelStep="11">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource OverlayOptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ContextMenuBackgroundBrush}" />
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource AccentOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OuterBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

