                                                        <Setter Property="Background" Value="#7F45F4" />
                                                        <Setter Property="BorderBrush" Value="#A56CFF" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Foreground" Value="White" />
                                                        <Setter Property="Cursor" Value="Hand" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="{x:Type Button}">
                                                                    <Border x:Name="RevealBorder"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="16">
                                                                        <Border.Background>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                                <GradientStop Color="#6D35EB" Offset="0" />
                                                                                <GradientStop Color="#A35AF2" Offset="1" />
                                                                            </LinearGradientBrush>
                                                                        </Border.Background>
                                                                        <ContentPresenter />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="RevealBorder" Property="Opacity" Value="0.95" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter TargetName="RevealBorder" Property="Opacity" Value="0.88" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
