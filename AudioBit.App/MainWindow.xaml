                                                                VerticalAlignment="Center"
                                                                Background="#1DCF6D"
                                                                CornerRadius="24">
                                                            <Canvas Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Ellipse Width="24" Height="24" Canvas.Left="1" Canvas.Top="1" Stroke="#EDFFF4" StrokeThickness="2" />
                                                                <Path Stroke="#EDFFF4"
                                                                      StrokeThickness="2.1"
