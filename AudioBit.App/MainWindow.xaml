                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="#D48BFF"
                                                               Text="{Binding RemoteConnectedProtocolText}"
                                                               TextAlignment="Center"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Margin="0,10,0,0"
                                                Height="1"
                                                Background="#303659" />

                                        <Button Margin="0,10,0,0"
                                                Height="44"
                                                Command="{Binding RemoveRemoteDeviceCommand}">
                                            <Button.Style>
                                                <Style TargetType="{x:Type Button}">
                                                    <Setter Property="Background" Value="#4C0B12" />
                                                    <Setter Property="BorderBrush" Value="#7A111A" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Setter Property="Foreground" Value="#FF4A51" />
                                                    <Setter Property="Cursor" Value="Hand" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type Button}">
