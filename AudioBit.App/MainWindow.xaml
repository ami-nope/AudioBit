                            <Border Grid.Column="0"
                                    Padding="8,6"
                                    CornerRadius="12"
                                    Background="{DynamicResource FooterHoverBrush}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Rectangle Width="3" Height="6" RadiusX="1" RadiusY="1" Canvas.Left="1" Canvas.Top="11" Fill="{DynamicResource FooterActiveBrush}" />
                                        <Rectangle Width="3" Height="10" RadiusX="1" RadiusY="1" Canvas.Left="6" Canvas.Top="7" Fill="{DynamicResource FooterActiveBrush}" />
                                        <Rectangle Width="3" Height="14" RadiusX="1" RadiusY="1" Canvas.Left="11" Canvas.Top="3" Fill="{DynamicResource FooterActiveBrush}" />
