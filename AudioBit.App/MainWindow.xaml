                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="Session" />
                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteSessionId}" TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="2"
                                                Margin="10,0,0,0"
                                                MinWidth="56"
                                                Command="{Binding CopyRemoteSessionIdCommand}"
                                                Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="10.5" FontWeight="SemiBold" Text="Copy" />
                                        </Button>
                                    </Grid>

                                    <Grid Margin="0,6,0,0">
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemoteSidPanelVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRemoteConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Text="Expires" />
                                        <TextBlock Grid.Column="1" Margin="10,0,0,0" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteSessionExpiresText}" />
                                    </Grid>

                                    <Button Margin="0,10,0,0"
                                            MinWidth="228"
                                            Height="38"
                                            HorizontalAlignment="Center"
                                            Command="{Binding GenerateRemoteQrCodeCommand}">
