<ui:FluentWindow x:Class="AudioBit.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:abui="clr-namespace:AudioBit.UI;assembly=AudioBit.UI"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="AudioBit"
                 Width="540"
                 Height="760"
                 MinWidth="440"
                 MinHeight="540"
                 Background="{DynamicResource WindowBackgroundBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ResizeMode="CanMinimize"
                 Topmost="{Binding IsAlwaysOnTop, Mode=TwoWay}">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid Margin="18">
        <Border Background="{DynamicResource WindowSurfaceBrush}"
                BorderThickness="0"
                CornerRadius="70">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource WindowTopBarBrush}"
                        BorderThickness="0"
                        CornerRadius="70,70,0,0">
                    <ui:TitleBar Title="AudioBit"
                                 Padding="20,14,18,14"
                                 Background="Transparent"
                                 ButtonsBackground="Transparent"
                                 ButtonsForeground="{DynamicResource TextPrimaryBrush}"
                                 ShowHelp="False"
                                 ShowMaximize="False"
                                 ShowMinimize="True">
                        <ui:TitleBar.Header>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="42"
                                        Height="42"
                                        Margin="0,0,14,0"
                                        Background="{DynamicResource PanelBackgroundBrush}"
                                        BorderThickness="0"
                                        CornerRadius="70">
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               Text="AB" />
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="AudioBit" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Per-process Windows audio mixer" />
                                </StackPanel>
                            </StackPanel>
                        </ui:TitleBar.Header>

                        <ui:TitleBar.CenterContent>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding CurrentDeviceName}" />
                                <TextBlock Margin="0,2,0,0"
                                           HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           Text="{Binding StatusText}" />
                            </StackPanel>
                        </ui:TitleBar.CenterContent>

                        <ui:TitleBar.TrailingContent>
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource TitleBarActionButtonStyle}"
                                        Command="{Binding ToggleSettingsCommand}">
                                    <TextBlock FontWeight="SemiBold" Text="Settings" />
                                </Button>

                                <Button Margin="0"
                                        Style="{StaticResource TitleBarActionButtonStyle}"
                                        Command="{Binding RefreshCommand}">
                                    <TextBlock FontWeight="SemiBold" Text="Refresh" />
                                </Button>
                            </StackPanel>
                        </ui:TitleBar.TrailingContent>
                    </ui:TitleBar>
                </Border>

                <Border Grid.Row="1"
                        Margin="20,16,20,0"
                        Padding="20"
                        Background="{DynamicResource PanelBackgroundBrush}"
                        BorderThickness="0"
                        CornerRadius="70"
                        Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Text="Window behavior" />
                            <CheckBox Margin="0,12,0,0"
                                      Style="{StaticResource SettingsCheckBoxStyle}"
                                      IsChecked="{Binding IsAlwaysOnTop, Mode=TwoWay}">
                                <TextBlock Text="Keep AudioBit on top" />
                            </CheckBox>
                            <CheckBox Style="{StaticResource SettingsCheckBoxStyle}"
                                      IsChecked="{Binding HideToTrayOnMinimize, Mode=TwoWay}">
                                <TextBlock Text="Hide to tray when minimized" />
                            </CheckBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="32,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="{Binding Sessions.Count, StringFormat=Active sessions: {0}}" />
                            <Button Margin="0,14,0,0"
                                    Padding="16,10"
                                    Style="{StaticResource TitleBarActionButtonStyle}"
                                    Command="{Binding ToggleMuteAllCommand}">
                                <TextBlock FontWeight="SemiBold" Text="Toggle Mute All" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="20">
                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                            BorderThickness="0"
                            CornerRadius="70">
                        <Grid>
                            <ListBox Padding="18"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ItemContainerStyle="{StaticResource SessionListBoxItemStyle}"
                                     ItemsSource="{Binding Sessions}"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <abui:AudioMeterControl PeakValue="{Binding Peak}"
                                                                CardOpacity="{Binding Opacity}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Grid Panel.ZIndex="10"
                                  Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Border Width="68"
                                            Height="68"
                                            HorizontalAlignment="Center"
                                            Background="#232323"
                                            BorderThickness="0"
                                            CornerRadius="70">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SecondaryAccentBrush}"
                                                   Text="AB" />
                                    </Border>
                                    <TextBlock Margin="0,18,0,0"
                                               HorizontalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="No active audio sessions" />
                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Start playback in any app to show live volume controls." />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
