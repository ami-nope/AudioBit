                                                              StrokeThickness="1.65"
                                                              StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round"
                                                              Data="M7.5,6.5 L16.5,6.5 M7.5,11.5 L13.5,11.5 M7.5,16.5 L10.5,16.5" />
                                                        <Path Fill="{DynamicResource AccentOrangeBrush}"
                                                              Data="M17.2,5.2 L19.8,5.2 L21.1,7 L19,9 L17.2,7 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="Low Performance Mode" />
                                                <TextBlock Margin="0,2,0,0"
                                                           FontSize="10.5"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Turns off hover motion, live visualisers, smooth scrolling, and inactive tile transparency. Defaults on for systems with 12 GB RAM or less."
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsLowPerformanceMode, Mode=TwoWay}"
                                                      Style="{StaticResource SettingsToggleStyle}" />
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                    <StackPanel Margin="0,6,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M7.5,8.5 C9.2,6.3 11.6,5.5 14,5.5 L15.8,5.5 M16.5,5.5 L16.5,9 M16.5,5.5 L12.8,5.5 M16.5,15.5 C14.8,17.7 12.4,18.5 10,18.5 L8.2,18.5 M7.5,18.5 L7.5,15 M7.5,18.5 L11.2,18.5" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Reset AudioBit Settings" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Restore all settings to their defaults." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Margin="0,10,0,0"
                                                Command="{Binding ShowResetConfirmationCommand}">
                                            <Button.Style>
                                                <Style BasedOn="{StaticResource SettingsDangerButtonStyle}" TargetType="{x:Type Button}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsResetConfirmationVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Reset All Settings" />
                                        </Button>

                                        <Grid Margin="0,10,0,0">
                                            <Grid.Style>
                                                <Style TargetType="{x:Type Grid}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsResetConfirmationVisible}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Command="{Binding CancelResetConfirmationCommand}" Style="{StaticResource SettingsActionButtonStyle}">
                                                <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Cancel" />
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding ConfirmResetSettingsCommand}" Style="{StaticResource SettingsDangerButtonStyle}">
                                                <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Confirm Reset" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                    <StackPanel Margin="0,12,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M12,4 L12,15 M8.5,7.5 L12,4 L15.5,7.5 M7,19 L17,19" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Export / Import Profiles" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Save or restore the current AudioBit settings snapshot." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Command="{Binding ExportProfilesCommand}" Style="{StaticResource SettingsActionButtonStyle}">
                                                <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Export" />
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding ImportProfilesCommand}" Style="{StaticResource SettingsActionButtonStyle}">
                                                <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Import" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                    <Grid Margin="0,12,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M8,7 C8.8,5.6 10.1,5 12,5 C15,5 16.5,7.3 16.5,10 C16.5,12.7 15,15 12,15 C9,15 7.5,12.7 7.5,10 C7.5,8.6 7.8,7.7 8.6,7.2 M11.2,15 L10,18.5 M12.8,15 L14,18.5 M9.5,11.2 L10.8,9.5 M14.5,11.2 L13.2,9.5" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Debug Mode" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Persisted only in this version." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                        <ToggleButton Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding DebugMode, Mode=TwoWay}" Style="{StaticResource SettingsToggleStyle}" />
                                    </Grid>

                                    <Border Height="1" Background="{DynamicResource DividerBrush}" />

                                    <Button Margin="0,12,0,6"
                                            Command="{Binding OpenLogFolderCommand}"
                                            Padding="0"
                                            Style="{StaticResource SettingsSectionHeaderButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" Background="{DynamicResource OverlayOptionBrush}" BorderBrush="{DynamicResource OverlayOptionBorderBrush}" BorderThickness="1" CornerRadius="10">
                                                <Viewbox Width="13" Height="13" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Stroke="{DynamicResource AccentOrangeBrush}" StrokeThickness="1.6" StrokeLineJoin="Round" Data="M3.5,9 L8.8,9 L10.6,6.7 L20.5,6.7 L20.5,17.8 L3.5,17.8 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="Open Log Folder" />
                                                <TextBlock Margin="0,2,0,0" FontSize="10.5" Foreground="{DynamicResource TextSecondaryBrush}" Text="Browse the AudioBit log directory." TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Path Grid.Column="2"
                                                  Width="8"
                                                  Height="12"
                                                  VerticalAlignment="Center"
                                                  Data="M1,1 L7,6 L1,11"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="BottomNavHost"
                            Grid.Row="5"
                            Background="{DynamicResource FooterBackgroundBrush}"
                            BorderBrush="{DynamicResource FooterBorderBrush}"
                            BorderThickness="0"
                            CornerRadius="0,0,28,28">
                        <Grid Margin="12,8,12,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Tag="Eq"
                                    Command="{Binding SelectEqTabCommand}"
                                    Style="{StaticResource FooterTabButtonStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Rectangle Width="3" Height="6" RadiusX="1" RadiusY="1" Canvas.Left="1" Canvas.Top="11" Style="{StaticResource FooterTabFillShapeStyle}" />
                                        <Rectangle Width="3" Height="10" RadiusX="1" RadiusY="1" Canvas.Left="6" Canvas.Top="7" Style="{StaticResource FooterTabFillShapeStyle}" />
                                        <Rectangle Width="3" Height="14" RadiusX="1" RadiusY="1" Canvas.Left="11" Canvas.Top="3" Style="{StaticResource FooterTabFillShapeStyle}" />
                                        <Rectangle Width="3" Height="9" RadiusX="1" RadiusY="1" Canvas.Left="16" Canvas.Top="8" Style="{StaticResource FooterTabFillShapeStyle}" />
                                    </Canvas>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource FooterTabTextStyle}"
                                               Text="EQ" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Tag="Remote"
                                    Command="{Binding SelectProfilesTabCommand}"
                                    Style="{StaticResource FooterTabButtonStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Path StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Style="{StaticResource FooterTabStrokeShapeStyle}"
                                              Data="M2.7,7 C6,3.8 12,3.8 15.3,7" />
                                        <Path StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Style="{StaticResource FooterTabStrokeShapeStyle}"
                                              Data="M4.9,9.8 C7.2,7.5 10.8,7.5 13.1,9.8" />
                                        <Path StrokeThickness="1.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Style="{StaticResource FooterTabStrokeShapeStyle}"
                                              Data="M7.2,12.3 C8.2,11.3 9.8,11.3 10.8,12.3" />
                                        <Ellipse Width="2.2"
                                                 Height="2.2"
                                                 Canvas.Left="7.9"
                                                 Canvas.Top="13.2"
                                                 Style="{StaticResource FooterTabFillShapeStyle}" />
                                    </Canvas>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource FooterTabTextStyle}"
                                               Text="Remote" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="SettingsButton"
                                    Grid.Column="2"
                                    Tag="Settings"
                                    Command="{Binding SelectSettingsTabCommand}"
                                    Style="{StaticResource FooterTabButtonStyle}">
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                 Style="{StaticResource OverflowContextMenuStyle}">
                                        <MenuItem Header="{Binding MonitoringMenuLabel}"
                                                  Command="{Binding ToggleMonitoringCommand}"
                                                  Style="{StaticResource OverflowMenuItemStyle}" />
                                        <Separator Style="{StaticResource OverflowSeparatorStyle}" />
                                        <MenuItem Header="Calibrate"
                                                  Command="{Binding OpenCalibrateCommand}"
                                                  Style="{StaticResource OverflowMenuItemStyle}" />
                                        <MenuItem Header="Calibrated Agents"
                                                  Command="{Binding OpenCalibratedAgentsCommand}"
                                                  Style="{StaticResource OverflowMenuItemStyle}" />
                                        <Separator Style="{StaticResource OverflowSeparatorStyle}" />
                                        <MenuItem Header="Minimize"
                                                  Click="MinimizeWindow_OnClick"
                                                  Style="{StaticResource OverflowMenuItemStyle}" />
                                        <MenuItem Header="Close"
                                                  Click="CloseWindow_OnClick"
                                                  Style="{StaticResource OverflowMenuItemStyle}" />
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Path StrokeThickness="1.4"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Style="{StaticResource FooterTabStrokeShapeStyle}"
                                              Data="M9,2.2 L10.6,2.6 L11.3,4.4 L13.1,4.9 L14.5,3.9 L15.8,5.2 L14.9,6.7 L15.4,8.5 L17.2,9.2 L17.2,10.8 L15.4,11.5 L14.9,13.3 L15.8,14.8 L14.5,16.1 L13.1,15.1 L11.3,15.6 L10.6,17.4 L9,17.8 L7.4,17.4 L6.7,15.6 L4.9,15.1 L3.5,16.1 L2.2,14.8 L3.1,13.3 L2.6,11.5 L0.8,10.8 L0.8,9.2 L2.6,8.5 L3.1,6.7 L2.2,5.2 L3.5,3.9 L4.9,4.9 L6.7,4.4 L7.4,2.6 Z" />
                                        <Ellipse Width="4.5"
                                                 Height="4.5"
                                                 Canvas.Left="6.75"
                                                 Canvas.Top="6.75"
                                                 StrokeThickness="1.4"
                                                 Style="{StaticResource FooterTabStrokeShapeStyle}" />
                                    </Canvas>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource FooterTabTextStyle}"
                                               Text="Settings" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    </Grid>

                    <Grid x:Name="OverlayLayer"
                          Grid.RowSpan="7"
                          Panel.ZIndex="30"
                          Visibility="{Binding IsAnyOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border x:Name="OverlayBlurLayer"
                                Margin="10"
                                CornerRadius="22"
                                Opacity="0.65"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <VisualBrush Visual="{Binding ElementName=ShellContentRoot}" />
                            </Border.Background>
                            <Border.Effect>
                                <BlurEffect Radius="18" />
                            </Border.Effect>
                        </Border>
                        <Border Margin="10"
                                Background="{DynamicResource OverlayShadeBrush}"
                                CornerRadius="22"
                                Opacity="0.75" />

                        <Border x:Name="CalibrateOverlayHost"
                                Width="300"
                                MaxHeight="490"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource OverlayPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding IsCalibrateOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="CalibrateOverlayShift" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Calibrate" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Tune the response profile" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding CloseOverlayCommand}"
                                            Style="{StaticResource OverlayCloseButtonStyle}">
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="X" />
                                    </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Margin="0,18,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="VerticalFirst"
                                              PanningDeceleration="0.001"
                                              infra:SmoothScrollBehavior.IsEnabled="{Binding EnableEnhancedVisuals}"
                                              infra:SmoothScrollBehavior.SmoothingDuration="250"
                                              infra:SmoothScrollBehavior.WheelStep="10"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                    </ScrollViewer.Resources>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Keep the calibration stack compact and aligned with the mixer shell." />

                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Mode" />

                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Tag="Adaptive"
                                                    Command="{Binding SelectCalibrationModeCommand}"
                                                    CommandParameter="Adaptive"
                                                    Style="{StaticResource CalibrateModeButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Adaptive" />
                                            </Button>

                                            <Button Grid.Column="2"
                                                    Tag="Manual"
                                                    Command="{Binding SelectCalibrationModeCommand}"
                                                    CommandParameter="Manual"
                                                    Style="{StaticResource CalibrateModeButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Manual" />
                                            </Button>
                                        </Grid>

                                        <TextBlock Margin="0,18,0,0"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Contour" />

                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Tag="Gentle"
                                                    Command="{Binding SelectCalibrationOptionCommand}"
                                                    CommandParameter="Gentle"
                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Gentle" />
                                            </Button>

                                            <Button Tag="Balanced"
                                                    Command="{Binding SelectCalibrationOptionCommand}"
                                                    CommandParameter="Balanced"
                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Balanced" />
                                            </Button>

                                            <Button Tag="Focused"
                                                    Margin="0,0,0,10"
                                                    Command="{Binding SelectCalibrationOptionCommand}"
                                                    CommandParameter="Focused"
                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Focused" />
                                            </Button>
                                        </WrapPanel>

                                        <Border Margin="0,8,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Calibration guide" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding CalibrationGuideText}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding CalibrationSummary}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>

                                <Button Grid.Row="2"
                                        Margin="0,18,0,0"
                                        Command="{Binding ApplyCalibrationCommand}"
                                        Style="{StaticResource OverlayPrimaryButtonStyle}">
                                    <TextBlock FontSize="14"
                                               FontWeight="SemiBold"
                                               Text="Apply Calibration" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border x:Name="SavedOverlayHost"
                                Width="300"
                                MaxHeight="470"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource OverlayPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding IsCalibratedAgentsOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="SavedOverlayShift" />
                            </Border.RenderTransform>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Calibrated Agents" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Saved profile snapshots" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding CloseOverlayCommand}"
                                            Style="{StaticResource OverlayCloseButtonStyle}">
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="X" />
                                    </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Margin="0,18,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
                                              PanningMode="VerticalFirst"
                                              PanningDeceleration="0.001"
                                              infra:SmoothScrollBehavior.IsEnabled="{Binding EnableEnhancedVisuals}"
                                              infra:SmoothScrollBehavior.SmoothingDuration="250"
                                              infra:SmoothScrollBehavior.WheelStep="10"
                                              VerticalScrollBarVisibility="Auto">
                                    <ScrollViewer.Resources>
                                        <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                                    </ScrollViewer.Resources>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Keep a compact snapshot of the current profile, device state, and calibration." />

                                        <Border Margin="0,14,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Selected profile" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding SelectedAgentName}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding SelectedAgentSummary}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,12,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Current device" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding DeviceDisplayName}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding StatusText}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,12,0,0"
                                                Padding="14"
                                                Background="{DynamicResource OverlaySoftCardBrush}"
                                                BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="Calibration snapshot" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           Text="{Binding AppliedCalibrationLabel}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           Text="{Binding SelectedAgentFootnote}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <Border x:Name="UpdateRestartOverlayHost"
                                Width="306"
                                MaxHeight="430"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource OverlayPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding IsUpdateRestartDialogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="Update Ready" />
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Text="Restart to finish installing" />
                                </StackPanel>

                                <TextBlock Grid.Row="1"
                                           Margin="0,16,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="AudioBit needs to restart to finish installing version " />
                                    <Run Text="{Binding AppPendingVersionText, Mode=OneWay}" />
                                    <Run Text="." />
                                </TextBlock>

                                <Border Grid.Row="2"
                                        Margin="0,14,0,0"
                                        Padding="14"
                                        Background="{DynamicResource OverlaySoftCardBrush}"
                                        BorderBrush="{DynamicResource OverlayOptionBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Visibility="{Binding HasUpdateSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Update summary" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="{Binding AppUpdateSummaryText}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Grid Grid.Row="3"
                                      Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding RestartUpdateLaterCommand}"
                                            Style="{StaticResource OverlaySecondaryButtonStyle}">
                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Text="Later" />
                                    </Button>

                                    <Button Grid.Column="2"
                                            Command="{Binding RestartForUpdateCommand}"
                                            Style="{StaticResource OverlayPrimaryButtonStyle}">
                                        <TextBlock FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Text="Restart now" />
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
