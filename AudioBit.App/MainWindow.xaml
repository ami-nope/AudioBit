                            <Grid Grid.Column="1"
                                  Margin="14,0,12,0"
                                  VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Output Device"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,4,0,0"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="{Binding DeviceDisplayName}"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Viewbox Grid.Column="2"
                                     Width="14"
                                     Height="14"
                                     VerticalAlignment="Center">
                                <Canvas Width="12" Height="12">
                                    <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                          StrokeThickness="1.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M3,2 L9,6 L3,10" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Border>

                    <Grid x:Name="MixerSectionHost"
                          Grid.Row="3"
                          Margin="18,18,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="APP MIXER" />

                        <Border Grid.Column="1"
                                Height="1"
                                Margin="12,10,0,0"
                                Background="{DynamicResource DividerBrush}"
                                VerticalAlignment="Center" />
                    </Grid>

                    <Grid x:Name="MixerListHost"
                          Grid.Row="4"
                          Margin="14,0,14,0">
                        <ListBox Padding="0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource SessionListBoxItemStyle}"
                                 ItemsSource="{Binding Sessions}"
                                 ScrollViewer.CanContentScroll="True"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Resources>
                                <Style BasedOn="{StaticResource SurfaceScrollBarStyle}" TargetType="{x:Type ScrollBar}" />
                            </ListBox.Resources>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <abui:AudioMeterControl CardOpacity="{Binding Opacity}"
                                                            PeakValue="{Binding Peak}" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Visibility="{Binding IsEmptyStateVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Border Width="72"
                                        Height="72"
                                        Background="{DynamicResource IconTileBrush}"
                                        BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Viewbox Width="34"
                                             Height="34"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Canvas Width="32" Height="32">
                                            <Path Stroke="{DynamicResource AccentOrangeBrush}"
                                                  StrokeThickness="3.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Margin="0,18,0,0"
                                           FontSize="17"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="No active app sessions" />
                                <TextBlock Margin="0,8,0,0"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Text="Start playback in any app to populate the mixer."
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Width="220" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="StatusFooterHost"
                          Grid.Row="5"
                          Margin="18,8,18,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource DividerBrush}" />

                        <TextBlock Grid.Column="1"
                                   Margin="10,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Text="{Binding SystemStatusText}"
                                   TextTrimming="CharacterEllipsis" />

                        <Border Grid.Column="2"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource DividerBrush}" />
                    </Grid>

