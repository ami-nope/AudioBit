                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock FontSize="10.5" Foreground="#8D95C2" Text="device_id" />
                                                    <TextBlock Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceIdText}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="1" FontSize="10.5" Foreground="#8D95C2" Text="device_name" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceNameText}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="2" FontSize="10.5" Foreground="#8D95C2" Text="device_location" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceLocationText}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="3" FontSize="10.5" Foreground="#8D95C2" Text="connection_type" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceConnectionTypeText}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="4" FontSize="10.5" Foreground="#8D95C2" Text="ip_address" />
                                                    <TextBlock Grid.Row="4" Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceIpAddressText}" TextWrapping="Wrap" />
                                                    <TextBlock Grid.Row="5" FontSize="10.5" Foreground="#8D95C2" Text="user_agent" />
                                                    <TextBlock Grid.Row="5" Grid.Column="1" FontSize="10.5" Foreground="{DynamicResource TextPrimaryBrush}" Text="{Binding RemoteDeviceUserAgentText}" TextWrapping="Wrap" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border Grid.Row="0"
                                                    Grid.Column="0"
                                                    Padding="8,8,8,8"
                                                    Background="#2A2E4A"
                                                    BorderBrush="#373F63"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock FontSize="11.5"
                                                               Foreground="#8D95C2"
                                                               Text="Latency"
                                                               TextAlignment="Center" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="14"
                                                               FontFamily="Consolas"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentOrangeBrush}"
                                                               Text="{Binding RemoteConnectedLatencyText}"
                                                               TextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="0"
                                                    Grid.Column="2"
                                                    Padding="8,8,8,8"
                                                    Background="#2A2E4A"
                                                    BorderBrush="#373F63"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock FontSize="11.5"
                                                               Foreground="#8D95C2"
                                                               Text="Strength"
                                                               TextAlignment="Center" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding RemoteConnectedStrengthBrush}"
                                                               Text="{Binding RemoteConnectedStrengthText}"
                                                               TextAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Row="1"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="3"
                                                    Margin="0,8,0,0"
                                                    Padding="8,8,8,8"
                                                    Background="#2A2E4A"
                                                    BorderBrush="#373F63"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
