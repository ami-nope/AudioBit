<Window x:Class="AudioBit.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:abui="clr-namespace:AudioBit.UI;assembly=AudioBit.UI"
        Title="AudioBit"
        Width="356"
        Height="690"
        MinWidth="356"
        MinHeight="690"
        MaxWidth="356"
        MaxHeight="690"
        Background="{DynamicResource WindowBackdropBrush}"
        FontFamily="Segoe UI"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Topmost="{Binding IsAlwaysOnTop, Mode=TwoWay}"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="HeaderUtilityButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Background" Value="{DynamicResource UtilityButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource UtilityButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource UtilityButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterNavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Padding="8,6"
                                Background="Transparent"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource FooterHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderBarButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Height="7"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3.5" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Width="18"
                                Height="18"
                                Background="{DynamicResource SliderThumbBrush}"
                                BorderBrush="{DynamicResource SliderThumbBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="9" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MasterSliderStyle" TargetType="{x:Type Slider}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Foreground" Value="{DynamicResource AccentOrangeBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid Margin="0,7,0,0">
                            <Track x:Name="PART_Track"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   IsDirectionReversed="{TemplateBinding IsDirectionReversed}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{TemplateBinding Foreground}"
                                                  Command="Slider.DecreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="{DynamicResource SliderInactiveBrush}"
                                                  Command="Slider.IncreaseLarge"
                                                  Style="{StaticResource SliderBarButtonStyle}" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SliderThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MasterSpeakerToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="RootBorder"
                                Width="24"
                                Height="24"
                                Background="Transparent"
                                CornerRadius="12">
                            <Viewbox Width="18"
                                     Height="18"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                                <Grid>
                                    <Canvas x:Name="SpeakerIcon" Width="24" Height="24">
                                        <Path Fill="{DynamicResource IconSecondaryBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15,9 C17,10.5 17,13.5 15,15" />
                                        <Path Stroke="{DynamicResource IconSecondaryBrush}"
                                              StrokeThickness="1.9"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M17.5,6.5 C21,9.2 21,14.8 17.5,17.5" />
                                    </Canvas>
                                    <Canvas x:Name="MuteIcon" Width="24" Height="24" Opacity="0">
                                        <Path Fill="{DynamicResource AccentOrangeBrush}"
                                              Data="M3,9 L7.5,9 L12,5.5 L12,18.5 L7.5,15 L3,15 Z" />
                                        <Path Stroke="{DynamicResource AccentOrangeBrush}"
                                              StrokeThickness="2.1"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M15.5,8.5 L20.5,15.5 M20.5,8.5 L15.5,15.5" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource FooterHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SpeakerIcon" Property="Opacity" Value="0" />
                                <Setter TargetName="MuteIcon" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SessionListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SurfaceScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbBorder"
                                                        Margin="2"
                                                        Background="{DynamicResource ScrollThumbBrush}"
                                                        CornerRadius="10" />
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Focusable="False"
                                                  Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverflowContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="{DynamicResource ContextMenuBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ContextMenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style x:Key="OverflowMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="RootBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource ContextMenuHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OverlayCloseButtonStyle"
               BasedOn="{StaticResource HeaderUtilityButtonStyle}"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style x:Key="OverlayOptionButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="{DynamicResource OverlayOptionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlayOptionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource OverlayOptionHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AgentOptionButtonStyle"
               BasedOn="{StaticResource OverlayOptionButtonStyle}"
               TargetType="{x:Type Button}">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="mixer-core" />
                        <Condition Binding="{Binding DataContext.SelectedAgentKey, RelativeSource={RelativeSource AncestorType=Window}}" Value="mixer-core" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="device-watch" />
                        <Condition Binding="{Binding DataContext.SelectedAgentKey, RelativeSource={RelativeSource AncestorType=Window}}" Value="device-watch" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="quiet-night" />
                        <Condition Binding="{Binding DataContext.SelectedAgentKey, RelativeSource={RelativeSource AncestorType=Window}}" Value="quiet-night" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalibrateModeButtonStyle"
               BasedOn="{StaticResource OverlayOptionButtonStyle}"
               TargetType="{x:Type Button}">
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Adaptive" />
                        <Condition Binding="{Binding DataContext.SelectedCalibrationMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Adaptive" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Manual" />
                        <Condition Binding="{Binding DataContext.SelectedCalibrationMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="Manual" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CalibrateOptionButtonStyle"
               BasedOn="{StaticResource OverlayOptionButtonStyle}"
               TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Gentle" />
                        <Condition Binding="{Binding DataContext.SelectedCalibrationOption, RelativeSource={RelativeSource AncestorType=Window}}" Value="Gentle" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Balanced" />
                        <Condition Binding="{Binding DataContext.SelectedCalibrationOption, RelativeSource={RelativeSource AncestorType=Window}}" Value="Balanced" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Focused" />
                        <Condition Binding="{Binding DataContext.SelectedCalibrationOption, RelativeSource={RelativeSource AncestorType=Window}}" Value="Focused" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource OverlaySelectedBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource OverlaySelectedBorderBrush}" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverlayPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Background" Value="{DynamicResource OverlayPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource OverlayPrimaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#FFFDF9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource OverlayPrimaryHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Border x:Name="ShellBorder"
                Background="{DynamicResource ShellBackgroundBrush}"
                BorderBrush="{DynamicResource ShellBorderBrush}"
                BorderThickness="1"
                CornerRadius="28">
            <Grid x:Name="ShellClipHost">
                <Border Background="{DynamicResource ShellSheenBrush}"
                        CornerRadius="28"
                        IsHitTestVisible="False" />

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="88" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="56" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource TopBarBackgroundBrush}"
                            BorderBrush="{DynamicResource TopBarBorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="28,28,0,0">
                        <Grid Margin="16,14,16,14"
                              MouseLeftButtonDown="Header_OnMouseLeftButtonDown">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Width="50"
                                    Height="50"
                                    Margin="0,0,12,0"
                                    Background="{DynamicResource BrandTileBrush}"
                                    BorderBrush="{DynamicResource BrandTileBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Viewbox Width="30"
                                         Height="30"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Stroke="{DynamicResource BrandGlyphBrush}"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Data="M4,16 L10,16 C12,16 12,11 14,11 C16,11 16,21 18,21 C20,21 20,8 22,8 C24,8 24,16 26,16 C28,16 28,12 30,12" />
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Text="AudioBit" />
                                <StackPanel Margin="0,5,0,0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Ellipse Width="6"
                                             Height="6"
                                             Margin="0,0,8,0"
                                             Fill="{DynamicResource AccentGreenBrush}" />
                                    <TextBlock FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Text="PRO CONTROLS" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Padding="2"
                                    Background="{DynamicResource UtilityGroupBrush}"
                                    BorderBrush="{DynamicResource UtilityGroupBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    VerticalAlignment="Top">
                                <Grid x:Name="HeaderUtilityHost">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Margin="0,0,2,0"
                                            ToolTip="{Binding ThemeToggleToolTip}"
                                            Command="{Binding ToggleThemeCommand}"
                                            Style="{StaticResource HeaderUtilityButtonStyle}">
                                        <Grid Width="16" Height="16">
                                            <Canvas Width="16" Height="16">
                                                <Canvas.Style>
                                                    <Style TargetType="{x:Type Canvas}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Canvas.Style>
                                                <Path Fill="{DynamicResource TextPrimaryBrush}"
                                                      Data="M10.8,1.5 C6.2,2.5 3.2,6.3 3.2,10.6 C3.2,13.5 4.7,16.1 7.2,17.5 C5.9,15.8 5.1,13.8 5.1,11.5 C5.1,6.8 8.4,2.8 12.8,1.5 C12.1,1.4 11.5,1.4 10.8,1.5 Z"
                                                      Stretch="Fill" />
                                            </Canvas>
                                            <Canvas Width="16" Height="16">
                                                <Canvas.Style>
                                                    <Style TargetType="{x:Type Canvas}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDarkTheme}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Canvas.Style>
                                                <Ellipse Width="8"
                                                         Height="8"
                                                         Canvas.Left="4"
                                                         Canvas.Top="4"
                                                         Fill="{DynamicResource TextPrimaryBrush}" />
                                                <Rectangle Width="2"
                                                           Height="4"
                                                           RadiusX="1"
                                                           RadiusY="1"
                                                           Canvas.Left="7"
                                                           Canvas.Top="0"
                                                           Fill="{DynamicResource TextPrimaryBrush}" />
                                                <Rectangle Width="2"
                                                           Height="4"
                                                           RadiusX="1"
                                                           RadiusY="1"
                                                           Canvas.Left="7"
                                                           Canvas.Top="12"
                                                           Fill="{DynamicResource TextPrimaryBrush}" />
                                                <Rectangle Width="4"
                                                           Height="2"
                                                           RadiusX="1"
                                                           RadiusY="1"
                                                           Canvas.Left="0"
                                                           Canvas.Top="7"
                                                           Fill="{DynamicResource TextPrimaryBrush}" />
                                                <Rectangle Width="4"
                                                           Height="2"
                                                           RadiusX="1"
                                                           RadiusY="1"
                                                           Canvas.Left="12"
                                                           Canvas.Top="7"
                                                           Fill="{DynamicResource TextPrimaryBrush}" />
                                            </Canvas>
                                        </Grid>
                                    </Button>

                                    <Button x:Name="OverflowButton"
                                            Grid.Column="1"
                                            Click="OverflowButton_OnClick"
                                            Style="{StaticResource HeaderUtilityButtonStyle}">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                                         Style="{StaticResource OverflowContextMenuStyle}">
                                                <MenuItem Header="{Binding MonitoringMenuLabel}"
                                                          Command="{Binding ToggleMonitoringCommand}"
                                                          Style="{StaticResource OverflowMenuItemStyle}" />
                                                <Separator />
                                                <MenuItem Header="Calibrate"
                                                          Command="{Binding OpenCalibrateCommand}"
                                                          Style="{StaticResource OverflowMenuItemStyle}" />
                                                <MenuItem Header="Calibrated Agents"
                                                          Command="{Binding OpenCalibratedAgentsCommand}"
                                                          Style="{StaticResource OverflowMenuItemStyle}" />
                                                <Separator />
                                                <MenuItem Header="Minimize"
                                                          Click="OverflowMinimizeItem_OnClick"
                                                          Style="{StaticResource OverflowMenuItemStyle}" />
                                                <MenuItem Header="Close"
