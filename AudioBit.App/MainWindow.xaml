                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Ellipse Width="6" Height="6" Canvas.Left="6" Canvas.Top="2" Fill="{DynamicResource FooterInactiveBrush}" />
                                        <Path Fill="{DynamicResource FooterInactiveBrush}"
                                              Data="M4,16 C4.4,12.6 6.8,10.5 9,10.5 C11.2,10.5 13.6,12.6 14,16 Z" />
                                    </Canvas>
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource FooterInactiveBrush}"
                                               Text="Profiles" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    IsEnabled="False"
                                    Style="{StaticResource FooterNavButtonStyle}">
                                <StackPanel HorizontalAlignment="Center">
                                    <Canvas Width="18" Height="18">
                                        <Path Stroke="{DynamicResource FooterInactiveBrush}"
                                              StrokeThickness="1.4"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M9,2.2 L10.6,2.6 L11.3,4.4 L13.1,4.9 L14.5,3.9 L15.8,5.2 L14.9,6.7 L15.4,8.5 L17.2,9.2 L17.2,10.8 L15.4,11.5 L14.9,13.3 L15.8,14.8 L14.5,16.1 L13.1,15.1 L11.3,15.6 L10.6,17.4 L9,17.8 L7.4,17.4 L6.7,15.6 L4.9,15.1 L3.5,16.1 L2.2,14.8 L3.1,13.3 L2.6,11.5 L0.8,10.8 L0.8,9.2 L2.6,8.5 L3.1,6.7 L2.2,5.2 L3.5,3.9 L4.9,4.9 L6.7,4.4 L7.4,2.6 Z" />
                                        <Ellipse Width="4.5" Height="4.5"
                                                 Canvas.Left="6.75"
                                                 Canvas.Top="6.75"
                                                 Stroke="{DynamicResource FooterInactiveBrush}"
                                                 StrokeThickness="1.4" />
                                    </Canvas>
                                    <TextBlock Margin="0,4,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource FooterInactiveBrush}"
                                               Text="Settings" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverlayLayer"
                          Grid.RowSpan="7"
                          Panel.ZIndex="30"
                          Visibility="{Binding IsOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Margin="10"
                                Background="{DynamicResource OverlayShadeBrush}"
                                CornerRadius="22" />

                        <Border x:Name="AgentsOverlayHost"
                                Width="300"
                                MaxHeight="470"
                                Padding="18"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource OverlayPanelBrush}"
                                BorderBrush="{DynamicResource OverlayPanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24"
                                Visibility="{Binding IsAgentsOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="Profiles" />
                                        <TextBlock Margin="0,4,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Text="Choose the profile shell" />
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding CloseOverlayCommand}"
                                            Style="{StaticResource OverlayCloseButtonStyle}">
                                        <TextBlock FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="X" />
                                    </Button>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              Margin="0,18,0,0"
                                              HorizontalScrollBarVisibility="Disabled"
