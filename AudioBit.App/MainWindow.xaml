                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Gentle" />
                                            </Button>

                                            <Button Tag="Balanced"
                                                    Command="{Binding SelectCalibrationOptionCommand}"
                                                    CommandParameter="Balanced"
                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Balanced" />
                                            </Button>

                                            <Button Tag="Focused"
                                                    Margin="0,0,0,10"
                                                    Command="{Binding SelectCalibrationOptionCommand}"
                                                    CommandParameter="Focused"
                                                    Style="{StaticResource CalibrateOptionButtonStyle}">
                                                <TextBlock FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Text="Focused" />
