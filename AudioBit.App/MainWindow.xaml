                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Command="{Binding RefreshRemotePairingCommand}"
                                                Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Renew Session" />
                                        </Button>
                                        <Button Grid.Column="2"
                                                Command="{Binding GenerateRemoteQrCodeCommand}"
                                                Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Refresh QR" />
                                        </Button>
                                    </Grid>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.Style>
                                            <Style TargetType="{x:Type Grid}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRemoteSidPanelVisible}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRemoteConnected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Command="{Binding RefreshRemotePairingCommand}" Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Renew Session" />
                                        </Button>
                                        <Button Grid.Column="2" Command="{Binding OpenRemoteQrCommand}" Style="{StaticResource SettingsActionButtonStyle}">
                                            <TextBlock HorizontalAlignment="Center" FontSize="11.5" FontWeight="SemiBold" Text="Open QR URL" />
                                        </Button>
                                    </Grid>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

